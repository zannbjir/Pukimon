<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Chess Fantasy — Realm of Pieces</title>

<!-- ══ SUPABASE SDK ══ -->
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>

<!-- ══ FONTS ══ -->
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700;900&family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=DM+Mono:wght@300;400&display=swap" rel="stylesheet"/>

<style>
/* ══════════════════════════════
   ROOT VARIABLES
══════════════════════════════ */
:root {
  --black:   #060606;
  --void:    #0c0c0c;
  --surface: #111111;
  --card:    #141414;
  --card2:   #1a1a1a;
  --border:  rgba(255,255,255,0.07);
  --gold:    #c9a96e;
  --gold2:   #e8c98a;
  --silver:  #9ba8b5;
  --crimson: #a03030;
  --sapphire:#2a4a8e;
  --emerald: #2a6a3e;
  --amethyst:#6a3a8e;
  --text:    #e8e2d9;
  --muted:   #5a5450;
  --glow-g:  rgba(201,169,110,0.12);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }

body {
  background: var(--black);
  color: var(--text);
  font-family: 'DM Mono', monospace;
  min-height: 100vh;
  overflow-x: hidden;
}

/* Noise texture */
body::before {
  content: '';
  position: fixed; inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");
  pointer-events: none; z-index: 999; opacity: 0.6;
}

/* Board pattern ambient */
body::after {
  content: '';
  position: fixed;
  top: -20%; left: -20%;
  width: 140%; height: 140%;
  background-image:
    repeating-conic-gradient(rgba(201,169,110,0.012) 0% 25%, transparent 0% 50%);
  background-size: 80px 80px;
  pointer-events: none;
  z-index: 0;
  animation: boardDrift 60s linear infinite;
}
@keyframes boardDrift { to { transform: translate(80px, 80px); } }

/* ══════════════════════════════
   SCROLLBAR
══════════════════════════════ */
::-webkit-scrollbar { width: 4px; height: 4px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

/* ══════════════════════════════
   HEADER / NAV
══════════════════════════════ */
.site-header {
  position: sticky; top: 0; z-index: 100;
  border-bottom: 1px solid var(--border);
  background: rgba(6,6,6,0.92);
  backdrop-filter: blur(16px);
  padding: 0 40px;
  display: flex; align-items: center;
  height: 64px; gap: 24px;
}
.logo {
  font-family: 'Cinzel', serif;
  font-size: 16px;
  font-weight: 700;
  letter-spacing: 0.1em;
  color: var(--gold);
  display: flex; align-items: center; gap: 10px;
  flex: 1;
}
.logo-piece { font-size: 22px; }
.nav-links { display: flex; gap: 6px; }
.nav-link {
  font-size: 10px;
  letter-spacing: 0.25em;
  color: var(--muted);
  text-decoration: none;
  padding: 6px 14px;
  border: 1px solid transparent;
  transition: all 0.2s;
  cursor: pointer;
  background: none;
  font-family: 'DM Mono', monospace;
}
.nav-link:hover, .nav-link.active {
  color: var(--gold);
  border-color: rgba(201,169,110,0.2);
  background: rgba(201,169,110,0.04);
}
.header-auth { display: flex; align-items: center; gap: 12px; }
.user-badge {
  display: flex; align-items: center; gap: 8px;
  font-size: 11px; color: var(--muted);
  padding: 6px 12px;
  border: 1px solid var(--border);
  border-radius: 2px;
}
.user-badge .char-icon { font-size: 16px; }
.btn-sm {
  font-family: 'DM Mono', monospace;
  font-size: 9px; letter-spacing: 0.25em;
  padding: 7px 16px;
  border-radius: 2px;
  cursor: pointer;
  transition: all 0.2s;
  text-transform: uppercase;
}
.btn-outline {
  background: transparent;
  border: 1px solid rgba(201,169,110,0.3);
  color: var(--gold);
}
.btn-outline:hover { background: rgba(201,169,110,0.08); border-color: var(--gold); }
.btn-ghost {
  background: transparent; border: 1px solid var(--border);
  color: var(--muted);
}
.btn-ghost:hover { color: var(--text); border-color: rgba(255,255,255,0.15); }

/* ══════════════════════════════
   HERO BANNER
══════════════════════════════ */
.hero {
  position: relative; z-index: 1;
  padding: 80px 40px 60px;
  text-align: center;
  overflow: hidden;
}
.hero::before {
  content: '♛';
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  font-size: 320px;
  color: rgba(201,169,110,0.03);
  pointer-events: none;
  animation: heroFloat 8s ease-in-out infinite;
  line-height: 1;
}
@keyframes heroFloat {
  0%,100% { transform: translate(-50%,-50%) scale(1); }
  50%      { transform: translate(-50%,-52%) scale(1.02); }
}
.hero-eyebrow {
  font-family: 'DM Mono', monospace;
  font-size: 10px; letter-spacing: 0.5em;
  color: var(--gold); opacity: 0.7;
  text-transform: uppercase;
  margin-bottom: 20px;
}
.hero-title {
  font-family: 'Cinzel', serif;
  font-size: clamp(36px, 7vw, 72px);
  font-weight: 900;
  line-height: 1.05;
  letter-spacing: 0.04em;
  background: linear-gradient(135deg, var(--text) 0%, var(--gold) 50%, var(--text) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 20px;
  animation: heroIn 1s ease forwards;
}
@keyframes heroIn { from { opacity:0; transform:translateY(20px); } to { opacity:1; transform:translateY(0); } }
.hero-sub {
  font-family: 'Cormorant Garamond', serif;
  font-size: 18px; font-weight: 300;
  color: rgba(232,226,217,0.55);
  max-width: 480px; margin: 0 auto 36px;
  line-height: 1.7;
  font-style: italic;
}
.hero-cta {
  display: flex; justify-content: center; gap: 12px;
}
.btn-primary {
  font-family: 'Cinzel', serif;
  font-size: 11px; letter-spacing: 0.2em;
  padding: 14px 32px;
  background: linear-gradient(135deg, var(--gold), #a07830);
  color: var(--black);
  border: none; border-radius: 2px;
  cursor: pointer; font-weight: 700;
  transition: all 0.3s;
  box-shadow: 0 0 30px rgba(201,169,110,0);
}
.btn-primary:hover { box-shadow: 0 0 30px rgba(201,169,110,0.25); transform: translateY(-1px); }

/* ══════════════════════════════
   PAGE / SECTIONS
══════════════════════════════ */
.page { position: relative; z-index: 1; }
.section { max-width: 1100px; margin: 0 auto; padding: 60px 40px; }
.sec-label {
  font-family: 'Cinzel', serif;
  font-size: 9px; letter-spacing: 0.5em;
  color: var(--gold); text-transform: uppercase;
  margin-bottom: 32px;
  display: flex; align-items: center; gap: 16px;
}
.sec-label::before, .sec-label::after {
  content: '◆';
  font-size: 6px; opacity: 0.4;
}
.sec-label::after { content: ''; flex: 1; height: 1px; background: var(--border); }
.sec-title {
  font-family: 'Cinzel', serif;
  font-size: 28px; font-weight: 700;
  color: var(--text); margin-bottom: 8px;
}

/* ══════════════════════════════
   CHARACTER CARDS
══════════════════════════════ */
.chars-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
  margin-bottom: 60px;
}
@media (max-width: 900px) { .chars-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 580px) { .chars-grid { grid-template-columns: 1fr; } }

.char-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 2px;
  padding: 28px 24px;
  position: relative; overflow: hidden;
  cursor: pointer;
  transition: all 0.35s cubic-bezier(0.23,1,0.32,1);
  animation: cardIn 0.6s ease both;
}
@keyframes cardIn { from { opacity:0; transform:translateY(24px); } to { opacity:1; transform:translateY(0); } }
.char-card:hover { transform: translateY(-4px); border-color: rgba(201,169,110,0.2); }
.char-card.selected { border-color: var(--gold); }

/* Card class-specific accent */
.char-card[data-class="king"]     { --c-accent: #c9a96e; --c-glow: rgba(201,169,110,0.1); }
.char-card[data-class="queen"]    { --c-accent: #9b6ec9; --c-glow: rgba(155,110,201,0.1); }
.char-card[data-class="bishop"]   { --c-accent: #e8e2d9; --c-glow: rgba(232,226,217,0.07); }
.char-card[data-class="knight"]   { --c-accent: #6e9bc9; --c-glow: rgba(110,155,201,0.1); }
.char-card[data-class="rook"]     { --c-accent: #a03030; --c-glow: rgba(160,48,48,0.1); }
.char-card[data-class="pawn"]     { --c-accent: #4ea86a; --c-glow: rgba(78,168,106,0.1); }
.char-card[data-class="warlock"]  { --c-accent: #8b5cf6; --c-glow: rgba(139,92,246,0.12); }
.char-card[data-class="necromancer"] { --c-accent: #7c3aed; --c-glow: rgba(124,58,237,0.14); }

.char-card::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0;
  height: 2px;
  background: var(--c-accent, var(--gold));
  opacity: 0; transition: opacity 0.3s;
}
.char-card:hover::before, .char-card.selected::before { opacity: 1; }
.char-card::after {
  content: '';
  position: absolute; inset: 0;
  background: radial-gradient(ellipse at top, var(--c-glow, transparent) 0%, transparent 65%);
  pointer-events: none; opacity: 0; transition: opacity 0.3s;
}
.char-card:hover::after, .char-card.selected::after { opacity: 1; }

.char-piece {
  font-size: 44px; line-height: 1;
  margin-bottom: 16px; display: block;
  filter: drop-shadow(0 0 12px var(--c-accent, var(--gold)));
  transition: transform 0.3s;
}
.char-card:hover .char-piece { transform: scale(1.1) translateY(-2px); }

.char-class {
  font-family: 'DM Mono', monospace;
  font-size: 8px; letter-spacing: 0.4em;
  color: var(--c-accent, var(--gold));
  text-transform: uppercase; margin-bottom: 6px;
}
.char-name {
  font-family: 'Cinzel', serif;
  font-size: 18px; font-weight: 700;
  color: var(--text); margin-bottom: 8px;
}
.char-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 13px; font-style: italic;
  color: var(--muted); margin-bottom: 16px;
}
.char-lore {
  font-size: 11px; color: rgba(232,226,217,0.5);
  line-height: 1.7; margin-bottom: 20px;
}
.char-stats {
  display: flex; gap: 12px; margin-bottom: 20px;
}
.stat {
  flex: 1; text-align: center;
  background: rgba(0,0,0,0.3);
  border: 1px solid var(--border);
  padding: 8px 4px; border-radius: 2px;
}
.stat-val {
  font-family: 'Cinzel', serif;
  font-size: 16px; font-weight: 700;
  color: var(--c-accent, var(--gold));
}
.stat-lbl { font-size: 8px; color: var(--muted); letter-spacing: 0.2em; margin-top: 2px; }

.skills-list { display: flex; flex-direction: column; gap: 8px; }
.skill-row {
  display: flex; align-items: center; gap: 10px;
  padding: 8px 10px;
  background: rgba(0,0,0,0.25);
  border: 1px solid var(--border);
  border-left: 2px solid var(--c-accent, var(--gold));
  border-radius: 0 2px 2px 0;
  transition: background 0.2s;
}
.char-card:hover .skill-row { background: rgba(0,0,0,0.35); }
.skill-emoji { font-size: 14px; flex-shrink: 0; }
.skill-info { flex: 1; }
.skill-name { font-size: 10px; font-weight: 400; color: var(--text); letter-spacing: 0.08em; }
.skill-desc { font-size: 9px; color: var(--muted); margin-top: 1px; }

.select-btn {
  width: 100%; margin-top: 16px;
  padding: 10px;
  font-family: 'Cinzel', serif; font-size: 10px; letter-spacing: 0.2em;
  background: transparent;
  border: 1px solid var(--c-accent, var(--gold));
  color: var(--c-accent, var(--gold));
  cursor: pointer; border-radius: 2px;
  transition: all 0.25s;
}
.select-btn:hover { background: rgba(255,255,255,0.05); }
.char-card.selected .select-btn {
  background: var(--c-accent, var(--gold));
  color: var(--black);
}

/* ══════════════════════════════
   CHAT ROOM
══════════════════════════════ */
.chat-layout {
  display: grid;
  grid-template-columns: 1fr 280px;
  gap: 20px;
  height: 560px;
}
@media (max-width: 720px) {
  .chat-layout { grid-template-columns: 1fr; height: auto; }
  .chat-sidebar { display: none; }
}
.chat-window {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 2px;
  display: flex; flex-direction: column;
  overflow: hidden;
}
.chat-header {
  padding: 16px 20px;
  border-bottom: 1px solid var(--border);
  display: flex; align-items: center; gap: 10px;
  background: rgba(0,0,0,0.2);
}
.chat-header-icon { font-size: 18px; }
.chat-header-title {
  font-family: 'Cinzel', serif; font-size: 13px;
  font-weight: 600; color: var(--text);
}
.chat-header-sub { font-size: 10px; color: var(--muted); margin-top: 1px; }
.live-dot {
  width: 6px; height: 6px;
  background: #4ea86a;
  border-radius: 50%; margin-left: auto;
  animation: pulse 2s infinite;
}
@keyframes pulse {
  0%,100% { box-shadow: 0 0 0 0 rgba(78,168,106,0.4); }
  50%      { box-shadow: 0 0 0 5px rgba(78,168,106,0); }
}
.chat-messages {
  flex: 1; overflow-y: auto;
  padding: 16px; display: flex; flex-direction: column; gap: 12px;
}
.msg {
  display: flex; gap: 10px; align-items: flex-start;
  animation: msgIn 0.3s ease;
}
@keyframes msgIn { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:translateY(0); } }
.msg.own { flex-direction: row-reverse; }
.msg-avatar {
  width: 32px; height: 32px; flex-shrink: 0;
  background: var(--surface);
  border-radius: 50%; border: 1px solid var(--border);
  display: flex; align-items: center; justify-content: center;
  font-size: 16px;
}
.msg-body { flex: 1; max-width: 75%; }
.msg.own .msg-body { align-items: flex-end; display: flex; flex-direction: column; }
.msg-meta {
  display: flex; align-items: center; gap: 6px;
  margin-bottom: 4px;
}
.msg.own .msg-meta { flex-direction: row-reverse; }
.msg-username {
  font-family: 'Cinzel', serif; font-size: 10px;
  font-weight: 600; color: var(--gold);
}
.msg-charname { font-size: 9px; color: var(--muted); letter-spacing: 0.1em; }
.msg-time { font-size: 8px; color: var(--muted); margin-left: auto; }
.msg-bubble {
  padding: 10px 14px;
  background: var(--card2);
  border: 1px solid var(--border);
  border-radius: 2px 8px 8px 8px;
  font-size: 12px; line-height: 1.6;
  color: rgba(232,226,217,0.9);
  word-break: break-word;
}
.msg.own .msg-bubble {
  background: rgba(201,169,110,0.08);
  border-color: rgba(201,169,110,0.2);
  border-radius: 8px 2px 8px 8px;
}
.msg-system {
  text-align: center; padding: 4px;
  font-size: 9px; color: var(--muted);
  letter-spacing: 0.2em;
}

.chat-input-wrap {
  padding: 16px;
  border-top: 1px solid var(--border);
  display: flex; gap: 10px;
  background: rgba(0,0,0,0.15);
}
.chat-input {
  flex: 1;
  background: rgba(255,255,255,0.03);
  border: 1px solid var(--border);
  border-radius: 2px;
  padding: 10px 14px;
  font-family: 'DM Mono', monospace;
  font-size: 12px; color: var(--text);
  outline: none; transition: border-color 0.25s;
  resize: none;
}
.chat-input::placeholder { color: var(--muted); }
.chat-input:focus { border-color: rgba(201,169,110,0.3); }
.send-btn {
  padding: 10px 16px;
  background: linear-gradient(135deg, var(--gold), #a07830);
  border: none; border-radius: 2px;
  color: var(--black); font-size: 16px;
  cursor: pointer; transition: all 0.2s;
  flex-shrink: 0;
}
.send-btn:hover { transform: scale(1.05); box-shadow: 0 0 16px rgba(201,169,110,0.3); }

/* Sidebar — online users */
.chat-sidebar {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 2px; overflow: hidden;
}
.sidebar-header {
  padding: 14px 18px;
  border-bottom: 1px solid var(--border);
  font-family: 'Cinzel', serif;
  font-size: 10px; letter-spacing: 0.25em;
  color: var(--gold); background: rgba(0,0,0,0.2);
}
.online-list { padding: 12px; display: flex; flex-direction: column; gap: 8px; }
.online-user {
  display: flex; align-items: center; gap: 10px;
  padding: 8px 10px;
  background: rgba(0,0,0,0.2);
  border: 1px solid var(--border); border-radius: 2px;
}
.online-piece { font-size: 20px; }
.online-info { flex: 1; }
.online-name { font-size: 11px; color: var(--text); }
.online-class { font-size: 9px; color: var(--muted); letter-spacing: 0.15em; }
.online-dot { width: 5px; height: 5px; background: #4ea86a; border-radius: 50%; }

/* ══════════════════════════════
   LOGIN MODAL
══════════════════════════════ */
.modal-overlay {
  position: fixed; inset: 0; z-index: 500;
  background: rgba(0,0,0,0.88);
  backdrop-filter: blur(8px);
  display: flex; align-items: center; justify-content: center;
  opacity: 0; pointer-events: none;
  transition: opacity 0.3s;
}
.modal-overlay.open { opacity: 1; pointer-events: all; }
.modal {
  background: var(--card);
  border: 1px solid rgba(201,169,110,0.2);
  border-radius: 2px;
  padding: 48px 40px;
  width: 420px; max-width: 90vw;
  position: relative;
  transform: translateY(20px);
  transition: transform 0.3s;
}
.modal-overlay.open .modal { transform: translateY(0); }
.modal-close {
  position: absolute; top: 16px; right: 16px;
  background: none; border: none;
  color: var(--muted); font-size: 18px; cursor: pointer;
  transition: color 0.2s;
}
.modal-close:hover { color: var(--text); }
.modal-piece {
  font-size: 48px; text-align: center;
  display: block; margin-bottom: 16px;
  filter: drop-shadow(0 0 16px var(--gold));
}
.modal-title {
  font-family: 'Cinzel', serif; font-size: 22px;
  font-weight: 700; text-align: center;
  color: var(--text); margin-bottom: 6px;
}
.modal-sub {
  font-size: 11px; color: var(--muted);
  text-align: center; margin-bottom: 32px;
  letter-spacing: 0.15em;
}
.modal-tabs {
  display: flex; gap: 0; margin-bottom: 28px;
  border: 1px solid var(--border); border-radius: 2px;
  overflow: hidden;
}
.modal-tab {
  flex: 1; padding: 10px;
  font-family: 'Cinzel', serif; font-size: 10px;
  letter-spacing: 0.2em; cursor: pointer;
  background: none; border: none; color: var(--muted);
  transition: all 0.2s;
}
.modal-tab.active { background: rgba(201,169,110,0.1); color: var(--gold); }
.form-group { margin-bottom: 16px; }
.form-label {
  display: block; font-size: 9px;
  letter-spacing: 0.3em; color: var(--muted);
  text-transform: uppercase; margin-bottom: 8px;
}
.form-input {
  width: 100%; padding: 12px 16px;
  background: rgba(255,255,255,0.03);
  border: 1px solid var(--border); border-radius: 2px;
  font-family: 'DM Mono', monospace;
  font-size: 12px; color: var(--text);
  outline: none; transition: border-color 0.25s;
}
.form-input:focus { border-color: rgba(201,169,110,0.35); }
.form-input::placeholder { color: var(--muted); }
.char-select-grid {
  display: grid; grid-template-columns: repeat(3, 1fr);
  gap: 8px; margin-bottom: 20px;
}
.char-pick {
  background: var(--surface);
  border: 1px solid var(--border); border-radius: 2px;
  padding: 10px 6px; cursor: pointer;
  text-align: center; transition: all 0.2s;
}
.char-pick:hover { border-color: rgba(201,169,110,0.3); background: rgba(201,169,110,0.04); }
.char-pick.selected { border-color: var(--gold); background: rgba(201,169,110,0.08); }
.char-pick-piece { font-size: 24px; display: block; margin-bottom: 4px; }
.char-pick-name { font-size: 9px; color: var(--muted); }
.modal-btn {
  width: 100%; padding: 14px;
  font-family: 'Cinzel', serif; font-size: 11px;
  letter-spacing: 0.25em; font-weight: 700;
  background: linear-gradient(135deg, var(--gold), #a07830);
  border: none; border-radius: 2px;
  color: var(--black); cursor: pointer;
  transition: all 0.3s;
}
.modal-btn:hover { box-shadow: 0 0 24px rgba(201,169,110,0.3); transform: translateY(-1px); }
.oauth-divider{display:flex;align-items:center;gap:10px;margin:16px 0 14px;color:var(--muted);font-size:9px;letter-spacing:0.22em;text-transform:uppercase}
.oauth-divider::before,.oauth-divider::after{content:'';flex:1;height:1px;background:linear-gradient(to right,transparent,var(--border),transparent)}
.oauth-btn{width:100%;padding:12px 14px;border-radius:2px;border:1px solid var(--border);background:rgba(255,255,255,0.03);color:var(--text);cursor:pointer;display:flex;align-items:center;justify-content:center;gap:10px;font-family:'DM Mono',monospace;font-size:12px;transition:all .2s}
.oauth-btn:hover{border-color:rgba(201,169,110,0.35);background:rgba(201,169,110,0.07)}
.google-logo{width:18px;height:18px;display:block;flex-shrink:0}
.wallet-badge{display:inline-flex;align-items:center;gap:8px;padding:6px 12px;border:1px solid rgba(201,169,110,0.24);background:rgba(201,169,110,0.08);border-radius:999px;font-size:10px;color:var(--text)}
.guide-note-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:16px;margin-top:18px}
.guide-note{background:var(--card);border:1px solid var(--border);padding:18px;border-radius:2px}
.guide-note h3{font-family:'Cinzel',serif;font-size:15px;color:var(--gold);margin-bottom:10px}
.guide-note p,.guide-note li{font-size:11px;color:rgba(232,226,217,0.76);line-height:1.85}
.guide-note ul{padding-left:18px}
.class-guide-modal{width:min(94vw,560px);max-height:min(90vh,860px);overflow:auto;text-align:left}
.class-guide-head{display:flex;align-items:center;gap:14px;margin-bottom:14px}
.class-guide-glyph{width:74px;height:74px;border-radius:18px;display:flex;align-items:center;justify-content:center;font-size:34px;border:1px solid rgba(201,169,110,.22);background:rgba(201,169,110,.08)}
.class-guide-kicker{font-size:9px;letter-spacing:.34em;color:var(--gold);text-transform:uppercase}
.class-guide-name{font-family:'Cinzel',serif;font-size:24px;color:var(--text);margin-top:4px}
.class-guide-text{font-size:12px;line-height:1.8;color:rgba(232,226,217,.72);margin-top:6px}
.class-guide-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px;margin-top:12px}
.class-guide-pill{padding:12px;border:1px solid var(--border);background:rgba(255,255,255,.02)}
.class-guide-pill b{display:block;font-size:10px;letter-spacing:.16em;color:var(--text);margin-bottom:4px}
.class-guide-actions{display:flex;justify-content:flex-end;gap:10px;flex-wrap:wrap;margin-top:16px}
@media (max-width:700px){.guide-note-grid,.class-guide-grid{grid-template-columns:1fr}}

.wallet-badge b{font-family:'Cinzel',serif;color:var(--gold);font-size:13px;letter-spacing:.06em}
.modal-error {
  font-size: 10px; color: #e57373;
  text-align: center; margin-top: 12px;
  min-height: 16px; letter-spacing: 0.1em;
}
.modal-note {
  font-size: 9px; color: var(--muted);
  text-align: center; margin-top: 16px;
  letter-spacing: 0.15em; line-height: 1.8;
  padding: 12px;
  background: rgba(201,169,110,0.04);
  border: 1px solid rgba(201,169,110,0.1);
  border-radius: 2px;
}

/* ══════════════════════════════
   MISC UTILITY
══════════════════════════════ */
.divider-fancy {
  display: flex; align-items: center; gap: 16px;
  padding: 0 40px; margin: 0;
}
.divider-fancy::before, .divider-fancy::after {
  content: ''; flex: 1; height: 1px;
  background: linear-gradient(to right, transparent, var(--border), transparent);
}
.divider-fancy span {
  font-size: 18px; color: var(--gold); opacity: 0.4;
  flex-shrink: 0;
}
.toast {
  position: fixed; bottom: 32px; right: 32px; z-index: 9999;
  background: var(--card);
  border: 1px solid rgba(201,169,110,0.3);
  border-left: 3px solid var(--gold);
  padding: 14px 20px;
  font-size: 12px; color: var(--text);
  border-radius: 2px;
  transform: translateX(120%);
  transition: transform 0.35s cubic-bezier(0.23,1,0.32,1);
  max-width: 300px;
}
.toast.show { transform: translateX(0); }
.needs-login-msg {
  text-align: center; padding: 40px;
  font-family: 'Cormorant Garamond', serif;
  font-size: 18px; font-style: italic;
  color: var(--muted);
}
.needs-login-msg .big-piece { font-size: 48px; display: block; margin-bottom: 16px; opacity: 0.3; }

.top-nav-wrap{display:flex;align-items:center;gap:10px;min-width:0}
@media (max-width: 900px){
  .site-header{padding:10px 14px;height:auto;flex-wrap:wrap;gap:12px}
  .logo{flex:1 1 100%;justify-content:center}
  .top-nav-wrap{width:100%;justify-content:space-between;gap:8px}
  .nav-links{overflow:auto;flex:1;padding-bottom:2px}
  .nav-links::-webkit-scrollbar{display:none}
  .header-auth{gap:8px}
  .hero{padding:48px 18px 36px}
  .hero-cta{flex-direction:column}
  .section{padding:36px 18px}
  .chat-layout {
        display: flex;
        flex-direction: column;
        height: auto;
    }
  .chat-sidebar {
        display: block !important; /* Munculkan di mobile */
        margin-top: 20px;
        order: 2;
    }
    .chat-window {
        order: 1;
        height: 500px; /* Batasi tinggi chat di mobile */
    }
  .chars-grid{grid-template-columns:1fr}
}
@media (max-width: 640px){
  .btn-sm{padding:7px 10px;letter-spacing:0.15em}
  .user-badge{padding:6px 9px;font-size:10px}
  .hero-sub{font-size:16px}
  .sec-title{font-size:22px}
}

html[data-theme="light"]{
  --black:#f4f5f7; --void:#ffffff; --surface:#ffffff; --card:#ffffff; --card2:#eef1f4;
  --border:rgba(15,23,42,0.10); --gold:#7b5a23; --gold2:#9b7430;
  --silver:#5d6774; --crimson:#b42318; --sapphire:#315ea8; --emerald:#1f7a4c; --amethyst:#7c3aed;
  --text:#121417; --muted:#6b7280; --glow-g:rgba(123,90,35,0.08);
}
body.simple-theme::before{opacity:.012}
body.simple-theme::after{display:none}
html[data-theme="light"] body::before{opacity:.008}
body.simple-theme .site-header,
body.simple-theme .char-card,
body.simple-theme .chat-window,
body.simple-theme .chat-sidebar,
body.simple-theme .modal,
body.simple-theme .online-user,
body.simple-theme .msg-bubble,
body.simple-theme .msg.own .msg-bubble,
body.simple-theme .skill-row,
body.simple-theme .stat{backdrop-filter:none;box-shadow:none}
body.simple-theme .hero-title{
  background:none;
  -webkit-text-fill-color:unset;
  color:var(--text);
}
.theme-toggle{
  border:1px solid rgba(201,169,110,0.3);
  background:transparent;color:var(--gold);
  padding:7px 14px;border-radius:2px;cursor:pointer;
  font:400 10px 'DM Mono',monospace;letter-spacing:.22em;text-transform:uppercase
}
.theme-toggle:hover{background:rgba(201,169,110,0.08)}

</style>
