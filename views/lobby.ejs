/* ── Check session on load (Supabase) ── */
// Ganti bagian checkSession lama dengan ini
async function checkSession() {
  // 1. Coba pulihkan dari LocalStorage dulu biar cepet
  try {
    const raw = localStorage.getItem(STORAGE_PROFILE_KEY);
    if (raw) {
      currentUser = JSON.parse(raw);
      updateHeaderAuth();
      updateChatSection();
      if (!DEMO_MODE) subscribeChat();
    }
  } catch(e) {}

  // 2. Validasi session asli ke server Supabase
  if (!DEMO_MODE && sb) {
    const { data } = await sb.auth.getSession();
    if (data?.session) {
      const u = data.session.user;
      const meta = u.user_metadata;
      onLoginSuccess({ 
        id: u.id, 
        email: u.email, 
        username: meta.username || meta.full_name || u.email.split('@')[0], 
        piece: meta.piece || '♞', 
        charName: meta.charName || 'Pejuang', 
        charClass: meta.charClass || 'none' 
      });
    } else {
      // Jika server bilang tidak ada session, pastikan tombol join muncul
      if (!currentUser) updateHeroCta(false);
    }
  } else {
    // Jika Demo Mode dan tidak ada data di storage
    if (!currentUser) updateHeroCta(false);
  }
}

// Update bagian startup (paling bawah)
window.addEventListener('load', () => {
  document.body.classList.add('simple-theme');
  loadTheme();
  
  // Langsung munculin tombol "Bergabung" sebagai fallback awal
  updateHeroCta(false); 
  
  // Baru cek session di background
  checkSession();
});

document.body.classList.add('simple-theme');
loadTheme();
checkSession();
