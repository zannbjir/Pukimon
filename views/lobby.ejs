<div style="height:80px;"></div>


<script>
/* ════════════════════════════════════════
   ██████╗  ██████╗
   CONFIG — GANTI DI SINI
   ████████████████████████████████████████ */

const SB_URL = '<%= supabaseUrl %>';
const SB_KEY = '<%= supabaseKey %>';

/* ════════════════════════════════════════
   INIT
════════════════════════════════════════ */
const DEMO_MODE = (SB_URL === 'YOUR_SUPABASE_URL');
let sb = null;
if (!DEMO_MODE) {
  sb = supabase.createClient(SB_URL, SB_KEY);
}

/* ── State ── */
let currentUser   = null;  // { id, email, username, piece, charClass, charName }
let selectedChar  = null;
let regChar       = { piece: '♞', cls: 'none' };
let messages      = [];
let onlineUsers   = [];
let realtimeSub   = null;
const STORAGE_PROFILE_KEY = 'cf_profile';
const STORAGE_WALLET_KEY = 'cf_wallet';
const STORAGE_THEME_KEY = 'cf_theme';

/* ════════════════════════════════════════
   DEMO MODE FAKE DATA
════════════════════════════════════════ */
const FAKE_USERS = [
  { id:'u1', username:'Gandalf', piece:'🌀', charName:'Arcanist', charClass:'queen' },
  { id:'u2', username:'Aragon',  piece:'👑', charName:'Commander',    charClass:'king'  },
  { id:'u3', username:'Legolas', piece:'🌙', charName:'Rider', charClass:'knight' },
];
const FAKE_MSGS = [
  { id:'m1', username:'Gandalf', piece:'🌀', charName:'Arcanist', message:'Selamat datang di Realm of Pieces!', ts: Date.now()-120000 },
  { id:'m2', username:'Aragon',  piece:'👑', charName:'Commander',    message:'Ayo bergabung dan pilih class favoritmu!', ts: Date.now()-60000 },
  { id:'m3', username:'Legolas', piece:'🌙', charName:'Rider', message:'Rider siap lompat ke petak mana saja 🌙', ts: Date.now()-30000 },
];


function readWallet(){
  try{
    const raw=localStorage.getItem(STORAGE_WALLET_KEY);
    if(raw){
      const parsed=JSON.parse(raw);
      return {coins:Number(parsed.coins||0),earned:Number(parsed.earned||0),spent:Number(parsed.spent||0),owned:Array.isArray(parsed.owned)?parsed.owned:[]};
    }
  }catch(e){}
  return {coins:0,earned:0,spent:0,owned:[]};
}

/* ════════════════════════════════════════
   AUTH
════════════════════════════════════════ */
async function doLogin() {
  const email = document.getElementById('loginEmail').value.trim();
  const pass  = document.getElementById('loginPass').value;
  setAuthError('');

  if (DEMO_MODE) {
    // Demo login simulation
    if (!email || !pass) { setAuthError('Isi email dan password!'); return; }
    const demoUser = {
      id: 'demo-' + Date.now(),
      email, username: email.split('@')[0],
      piece: '👑', charName: 'Commander', charClass: 'king'
    };
    onLoginSuccess(demoUser);
    return;
  }

  try {
    const { data, error } = await sb.auth.signInWithPassword({ email, password: pass });
    if (error) { setAuthError(error.message); return; }
    const meta = data.user.user_metadata;
    onLoginSuccess({
      id: data.user.id, email: data.user.email,
      username: meta.username || data.user.email.split('@')[0],
      piece: meta.piece || '♞',
      charName: meta.charName || 'Pejuang Realm',
      charClass: meta.charClass || 'none'
    });
  } catch(e) { setAuthError('Gagal login. Cek koneksi.'); }
}

async function doGoogleLogin(){
  window.location.href = '/auth/google';
}

async function doGithubLogin() {
    window.location.href = '/auth/github';
}

async function handleAuthRedirect() {
    const { data } = await sb.auth.getSession();
    if (data?.session) {
        // Bersihkan URL dari hash token agar rapi
        window.history.replaceState({}, document.title, window.location.pathname);
        const u = data.session.user;
        const meta = u.user_metadata;
        onLoginSuccess({ 
            id: u.id, email: u.email, 
            username: meta.username || meta.full_name || u.email.split('@')[0], 
            piece: meta.piece || '♞', 
            charName: meta.charName || 'Pejuang', 
            charClass: meta.charClass || 'none' 
        });
    }
}
window.addEventListener('load', handleAuthRedirect);

async function doRegister() {
  const name  = document.getElementById('regName').value.trim();
  const email = document.getElementById('regEmail').value.trim();
  const pass  = document.getElementById('regPass').value;
  setAuthError('');

  if (!name || !email || !pass) { setAuthError('Semua kolom wajib diisi!'); return; }
  if (pass.length < 6) { setAuthError('Password minimal 6 karakter!'); return; }

  const charData = {
    username: name,
    piece: '♞',
    charClass: 'none',
    charName: 'Pejuang Realm'
  };

  if (DEMO_MODE) {
    const demoUser = { id: 'demo-' + Date.now(), email, ...charData };
    onLoginSuccess(demoUser);
    return;
  }

  try {
    const { data, error } = await sb.auth.signUp({
      email, password: pass,
      options: { data: charData }
    });
    if (error) { setAuthError(error.message); return; }
    const meta = data.user.user_metadata;
    onLoginSuccess({ id: data.user.id, email, username: meta.username || name, piece: meta.piece || '♞', charName: meta.charName || 'Pejuang Realm', charClass: meta.charClass || 'none' });
    showToast('✨ Selamat datang di Realm!');
  } catch(e) { setAuthError('Gagal register. Coba lagi.'); }
}

function persistProfile(user){ try{ localStorage.setItem(STORAGE_PROFILE_KEY, JSON.stringify(user)); }catch(e){} }

function onLoginSuccess(user) {
  currentUser = user;
  persistProfile(user);
  closeModal();
  updateHeaderAuth();
  updateChatSection();
  updateHeroCta(true);
  if (!DEMO_MODE) subscribeChat();
  showToast(`⚔ ${user.username} telah memasuki Realm!`);
  addOnlineUser(user);
}

async function doLogout() {
  if (!DEMO_MODE && sb) await sb.auth.signOut();
  if (realtimeSub) { sb.removeChannel(realtimeSub); realtimeSub = null; }
  removeOnlineUser(currentUser?.id);
  currentUser = null;
  try{ localStorage.removeItem(STORAGE_PROFILE_KEY); }catch(e){}
  updateHeaderAuth();
  updateChatSection();
  showToast('Kamu telah meninggalkan Realm.');
}

/* ════════════════════════════════════════
   SUPABASE REALTIME CHAT
════════════════════════════════════════ */
let lastMsgId = null;

function updateOnlineUsersFromChat(allMsgs) {
    const fiveMinutesAgo = Date.now() - (5 * 60 * 1000);
    const uniqueUsers = [];
    const seen = new Set();

    allMsgs.forEach(m => {
        const msgTs = new Date(m.created_at).getTime();
        if (msgTs > fiveMinutesAgo && !seen.has(m.username)) {
            seen.add(m.username);
            uniqueUsers.push({
                username: m.username,
                piece: m.character_piece || '♞',
                charName: m.character_name || 'Pejuang'
            });
        }
    });

    onlineUsers = uniqueUsers;
    renderOnlineList();
}

async function loadMessages() {
    if (DEMO_MODE || !sb) return;

    try {
        const { data, error } = await sb.from('chat_messages')
            .select('*')
            .order('created_at', { ascending: false })
            .limit(50);

        if (error) throw error;

        if (data && data.length > 0) {
            // Cek apakah pesan terbaru berbeda dengan yang lama
            if (data[0].id !== lastMsgId) {
                lastMsgId = data[0].id;
                // Balik urutan agar yang lama di atas
                messages = data.reverse().map(m => ({
                    id: m.id, username: m.username,
                    piece: m.character_piece, charName: m.character_name,
                    message: m.message, ts: new Date(m.created_at).getTime()
                }));
                renderMessages();
            }
            
            // Logika Pejuang Online: Ambil user unik yang chat dalam 5 menit terakhir
            updateOnlineUsersFromChat(data);
        }
    } catch (e) {
        console.error('Fetch error:', e);
    }
}

let chatChannel = null;

function subscribeChat() {
    if (!sb || !currentUser) return;

    // 1. Inisialisasi Channel
    chatChannel = sb.channel('room-utama', {
        config: {
            presence: { key: currentUser.username },
        },
    });

    // 2. Dengerin Chat Baru (Realtime Insert)
    chatChannel.on('postgres_changes', { 
        event: 'INSERT', 
        schema: 'public', 
        table: 'chat_messages' 
    }, payload => {
        const m = payload.new;
        // Cek supaya tidak double (Optimistic UI)
        if (!messages.find(msg => msg.id === m.id)) {
            messages.push({
                id: m.id, username: m.username,
                piece: m.character_piece, charName: m.character_name,
                message: m.message, ts: new Date(m.created_at).getTime()
            });
            renderMessages();
        }
    });

    // 3. LOGIKA PEJUANG ONLINE (Presence)
    chatChannel
        .on('presence', { event: 'sync' }, () => {
            const state = chatChannel.presenceState();
            // Ubah object state Supabase jadi array user yang enak dibaca
            onlineUsers = Object.keys(state).map(key => {
                const userPresence = state[key][0]; // Ambil data pertama
                return {
                    username: key,
                    piece: userPresence.piece || '♞',
                    charName: userPresence.charName || 'Pejuang'
                };
            });
            renderOnlineList();
        })
        .on('presence', { event: 'join', key: key => {
             showToast(`⚔ ${key} masuk ke medan perang!`);
        }})
        .on('presence', { event: 'leave', key: key => {
             // Otomatis terpicu saat user tutup browser
             console.log(`${key} meninggalkan arena`);
        }});

    // 4. Register diri kita agar terhitung "Online"
    chatChannel.subscribe(async (status) => {
        if (status === 'SUBSCRIBED') {
            await chatChannel.track({
                piece: currentUser.piece,
                charName: currentUser.charName,
                online_at: new Date().toISOString(),
            });
        }
    });
}

async function sendMsg() {
  const input = document.getElementById('chatInput');
  const text = input.value.trim();
  
  // 1. Cek validasi dasar
  if (!text || !currentUser) return;
  
  // 2. Langsung kosongin input biar enak buat ngetik lagi
  input.value = '';

  // 3. Buat data pesan sementara (Ini yang bikin instan)
  const tempId = 'temp-' + Date.now();
  const msgData = {
    id: tempId,
    username: currentUser.username,
    piece: currentUser.piece,
    charName: currentUser.charName,
    message: text,
    ts: Date.now()
  };

  // 4. Langsung tampilin ke layar tanpa nunggu database
  messages.push(msgData);
  renderMessages();

  // Mode Demo: Selesai di sini
  if (DEMO_MODE) return;

  // 5. Baru deh kirim ke Supabase di "backstage"
  try {
    const { error } = await sb.from('chat_messages').insert({
      user_id: currentUser.id,
      username: currentUser.username,
      character_piece: currentUser.piece,
      character_name: currentUser.charName,
      message: text
    });

    if (error) throw error;

  } catch(e) {
    console.error('Kirim gagal:', e);
    // Kalau gagal beneran, kita hapus pesan palsu tadi atau kasih tanda merah
    showToast('Pesan gagal terkirim ke server, jir.');
  }
}

// Pastikan fungsi renderMessages kamu punya fitur auto-scroll ke bawah:
function renderMessages() {
  const box = document.getElementById('chatMessages');
  if (!box) return;

  box.innerHTML = messages.map(m => {
    const isOwn = currentUser && m.username === currentUser.username;
    const time = new Date(m.ts).toLocaleTimeString('id-ID', { hour:'2-digit', minute:'2-digit' });
    return `
      <div class="msg ${isOwn ? 'own' : ''}">
        <div class="msg-avatar">${m.piece}</div>
        <div class="msg-body">
          <div class="msg-meta">
            <span class="msg-username">${escHtml(m.username)}</span>
            <span class="msg-charname">${escHtml(m.charName || '')}</span>
            <span class="msg-time">${time}</span>
          </div>
          <div class="msg-bubble">${escHtml(m.message)}</div>
        </div>
      </div>`;
  }).join('');

  // AUTO-SCROLL KE BAWAH
  box.scrollTop = box.scrollHeight;
}

function escHtml(s) {
  return String(s)
    .replace(/&/g,'&amp;')
    .replace(/</g,'&lt;')
    .replace(/>/g,'&gt;');
}

/* ════════════════════════════════════════
   ONLINE USERS
════════════════════════════════════════ */
function addOnlineUser(user) {
  if (!onlineUsers.find(u => u.id === user.id)) onlineUsers.push(user);
  renderOnlineList();
}
function removeOnlineUser(id) {
  onlineUsers = onlineUsers.filter(u => u.id !== id);
  renderOnlineList();
}
function renderOnlineList() {
    const list = document.getElementById('onlineList');
    if (!list) return;

    // Update Judul Sidebar dengan jumlah pejuang
    const sidebarHeader = document.querySelector('.sidebar-header');
    if (sidebarHeader) {
        sidebarHeader.innerHTML = `⚔ Pejuang Online (${onlineUsers.length})`;
    }

    if (onlineUsers.length === 0) {
        list.innerHTML = '<div class="msg-system">Menghubungkan ke Realm...</div>';
        return;
    }

    list.innerHTML = onlineUsers.map(u => `
        <div class="online-user">
            <span class="online-piece" style="filter: drop-shadow(0 0 5px var(--gold));">${u.piece}</span>
            <div class="online-info">
                <div class="online-name">${escHtml(u.username)}</div>
                <div class="online-class">${escHtml(u.charName)}</div>
            </div>
            <div class="online-dot"></div>
        </div>`).join('');
}

/* ════════════════════════════════════════
   UI HELPERS
════════════════════════════════════════ */
function updateHeaderAuth() {
  const el = document.getElementById('headerAuth');
  if (currentUser) {
    const wallet = readWallet();
    el.innerHTML = `
      <div class="wallet-badge"><span>🪙</span><span><small style="color:var(--muted);display:block;line-height:1">Coins</small><b>${wallet.coins}</b></span></div>
      <div class="user-badge">
        <span class="char-icon">${currentUser.piece}</span>
        <span>${currentUser.username}</span>
      </div>
      <button class="btn-sm btn-ghost" onclick="doLogout()">Keluar</button>`;
    
    // Panggil fungsi update tombol di Hero
    updateHeroCta(true);
  } else {
    el.innerHTML = `
      <button class="theme-toggle" id="themeToggleBtn" onclick="toggleTheme()">☀ LIGHT</button>
      <button class="btn-sm btn-outline" onclick="openModal()">Login / Register</button>`;
    updateHeroCta(false);
  }
}

function updateHeroCta(isLoggedIn) {
  const cta = document.getElementById('heroCta');
  if (!cta) return; // Mencegah error jika elemen belum render

  if (isLoggedIn && currentUser) {
    cta.innerHTML = `
      <button class="btn-primary" onclick="openBattleClient()">⚔ Masuk Arena</button>
      <button class="btn-primary" onclick="showPage('chat')">💬 Ruang Perang</button>
      <button class="btn-primary" onclick="showPage('events')">🏆 Event</button>
    `;
  } else {
    // Tombol default saat belum login
    cta.innerHTML = `
      <button class="btn-primary" onclick="openModal()">⚔ Bergabung Sekarang</button>
      <button class="btn-sm btn-ghost" onclick="showPage('skills')">Lihat Skill Atlas →</button>
    `;
  }
}

let chatPoller = null;

function updateChatSection() {
  const out = document.getElementById('chatLoggedOut');
  const inn = document.getElementById('chatLoggedIn');
  if (!out || !inn) return;
  if (currentUser) {
    out.style.display = 'none';
    inn.style.display = 'block';
    loadMessages();
    
    // Mulai polling otomatis setiap 3 detik agar pesan baru muncul tanpa refresh
    if (!chatPoller) {
      chatPoller = setInterval(() => {
        // Hanya fetch jika user sedang membuka halaman chat
        if (document.getElementById('pageChat').style.display === 'block') {
          loadMessages();
        }
      }, 3000);
    }
  } else {
    out.style.display = 'block';
    inn.style.display = 'none';
    if (chatPoller) {
      clearInterval(chatPoller);
      chatPoller = null;
    }
  }
}

function showPage(name, trigger) {
  document.getElementById('heroSection').style.display = name === 'home' ? 'block' : 'none';
  document.getElementById('pageSkills').style.display  = name === 'skills' ? 'block' : 'none';
  document.getElementById('pageEvents').style.display  = name === 'events' ? 'block' : 'none';
  document.getElementById('pageChat').style.display    = name === 'chat' ? 'block' : 'none';
  document.querySelectorAll('.nav-link').forEach(l => l.classList.remove('active'));
  if (trigger) trigger.classList.add('active');
  else {
    const map = {home:0, skills:1, chat:2};
    const btns = document.querySelectorAll('.nav-link');
    if (btns[map[name]]) btns[map[name]].classList.add('active');
  }
  if (name === 'chat') updateChatSection();
}

function openModal() {
  document.getElementById('authModal').classList.add('open');
  document.getElementById('demoNote').style.display = DEMO_MODE ? 'block' : 'none';
}
function closeModal() { document.getElementById('authModal').classList.remove('open'); }
document.getElementById('authModal').addEventListener('click', e => {
  if (e.target === document.getElementById('authModal')) closeModal();
});

function switchTab(tab) {
  document.getElementById('formLogin').style.display    = tab === 'login'    ? 'block' : 'none';
  document.getElementById('formRegister').style.display = tab === 'register' ? 'block' : 'none';
  document.getElementById('tabLogin').classList.toggle('active', tab === 'login');
  document.getElementById('tabReg').classList.toggle('active', tab === 'register');
  setAuthError('');
}

function setAuthError(msg) { document.getElementById('authError').textContent = msg; }

