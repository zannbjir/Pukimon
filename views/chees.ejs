.mb-state{display:flex;gap:4px;flex-wrap:wrap;margin-top:6px}
.mb-state span{
  font-size:8px;padding:3px 7px;border-radius:999px;
  border:1px solid rgba(255,255,255,0.08);background:rgba(255,255,255,0.03);color:var(--text2)
}
.mb-skill{
