.mb-name{font-family:'Cinzel',serif;font-size:11px;letter-spacing:0.08em;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.mb-hp-line{display:flex;justify-content:space-between;gap:8px;font-size:9px;color:var(--muted);margin:4px 0}
.mb-hp-track{height:5px;background:rgba(255,255,255,0.08);border-radius:999px;overflow:hidden}
.mb-hp-fill{height:100%;background:linear-gradient(to right,var(--green),var(--gold));width:100%;transition:width .35s ease}
