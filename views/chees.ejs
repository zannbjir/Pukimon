async function startRankedMatchmaking(){
  G.adminSandbox=false;
  G.tutorialMode=false;
  updateAdminButton();
  if(DEMO){showToast('⚠ Ranked player butuh backend online aktif.');return;}
  if(!sb){showToast('Supabase client belum aktif.');return;}
  clearMatchmakingPolling();
  G.mode='online';
  G.rankMode=true;
  G.onlineRanked=true;
  G.playerColor='w';
  G.myName=getName();
  G.myClass=document.querySelector('.class-btn.sel').dataset.cls;
  saveProfileToStorage();
  const tier=getCurrentRankTier();
  G.matchmakingTier=tier.name;
  G.roomStatus='queue';
  G.enemyName='Searching...';
  G.enemyClass='queen';
  G.selfConfig={w:{name:G.myName,cls:G.myClass},b:{name:'Searching...',cls:'queen'}};
  G.flipped=false;
  setWaitScreen('matchmaking', tier.name);
  showScreen('waitScreen');
  const {data:rooms,error}=await sb.from('game_rooms').select('*').eq('status','queue').order('created_at',{ascending:true}).limit(30);
  if(error){showToast('Gagal akses queue ranked. Cek Supabase.');showScreen('lobbyScreen');return;}
  const candidate=(rooms||[]).find(room=>{
    const wp=room.white_player||{};
    const roomTier=wp.rankTier || wp.rank_tier || room.rank_tier || 'Bronze';
    return roomTier===tier.name && wp.id!==G.currentUserId;
  });
  if(candidate){
    G.playerColor='b';
    G.roomId=candidate.id;
    G.roomCode=candidate.room_code;
    G.roomVersion=candidate.version||0;
    const wp=candidate.white_player||{};
    G.enemyName=wp.name||'Ranked Rival';
    G.enemyClass=wp.cls||'queen';
    G.selfConfig={w:{name:G.enemyName,cls:G.enemyClass},b:{name:G.myName,cls:G.myClass}};
    const {data:joined,error:updateErr}=await sb.from('game_rooms').update({
      black_player:{id:G.currentUserId,name:G.myName,cls:G.myClass,rankTier:tier.name},
      status:'playing',
      updated_at:new Date().toISOString()
    }).eq('id',candidate.id).eq('status','queue').select().single();
    if(updateErr||!joined){
      showToast('Lawan baru saja terambil. Coba cari lagi.');
      G.roomId=null; G.roomCode=null; G.playerColor='w';
      showScreen('lobbyScreen');
      return;
    }
    G.roomVersion=joined.version||G.roomVersion;
    G.roomStatus='playing';
    G.state=joined.game_state||makeState();
    persistRoomMeta();
    initGame();
    showScreen('gameScreen');
    subscribeRoom();
    await loadRoomMessages();
    addChatMsg('system',`🏆 Ranked PvP dimulai. Matchmaking menemukan lawan tier ${tier.name}.`);
    return;
  }
  const code=`MM${Math.random().toString(36).slice(2,6).toUpperCase()}`;
  const baseState=makeState();
  const payload={
    room_code:code,
    white_player:{id:G.currentUserId,name:G.myName,cls:G.myClass,rankTier:tier.name},
    status:'queue',
    version:0,
    game_state:baseState
  };
  const {data:created,error:createErr}=await sb.from('game_rooms').insert(payload).select().single();
  if(createErr||!created){showToast('Gagal masuk antrean ranked.');showScreen('lobbyScreen');return;}
  G.roomId=created.id;
  G.roomCode=created.room_code;
  G.roomVersion=created.version||0;
  G.state=created.game_state||baseState;
  persistRoomMeta();
  subscribeRoom();
  beginMatchmakingPolling();
  addChatMsg('system',`🏆 Masuk antrean ranked tier ${tier.name}. Menunggu lawan...`);
}

async function startVsFriend(){
  G.adminSandbox=false;
  G.tutorialMode=false;
  updateAdminButton();
  if(DEMO){showToast('⚠ Online mode butuh backend online aktif.');return;}
  G.mode='online';
  G.onlineRanked=false;
  G.rankMode=false;
  G.playerColor='w';
  G.myName=getName();
  G.myClass=document.querySelector('.class-btn.sel').dataset.cls;
  saveProfileToStorage();
  G.selfConfig={w:{name:G.myName,cls:G.myClass},b:{name:'Lawan',cls:'queen'}};
  G.flipped=false;
  // Generate room code
  const code=Math.random().toString(36).substr(2,4).toUpperCase();
  G.roomCode=code;
  document.getElementById('waitCode').textContent=code;
  updateRoomCodeButtons();
  showScreen('waitScreen');
  await createOnlineRoom(code);
}

async function joinRoom() {
    const code = document.getElementById('joinCodeInp').value.trim().toUpperCase();
    if (!code) { showToast('Masukkan kode room!'); return; }

    // Ambil user terbaru
    const { data: { session } } = await sb.auth.getSession();
    if (!session) {
        showToast('Kamu harus login dulu!');
        return;
    }
    
    currentUser = session.user;
    G.currentUserId = currentUser.id;
    G.myName = currentUser.user_metadata.username || getName();
    
    // Set state awal sebelum masuk fungsi join
    G.mode = 'online';
    G.playerColor = 'b';
    G.flipped = true;
    G.roomCode = code;

    await joinOnlineRoom(code);
}

