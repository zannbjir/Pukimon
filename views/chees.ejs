}
.sel-inp:focus{border-color:rgba(201,169,110,0.3)}
.custom-help{font-size:10px;color:var(--muted);line-height:1.7}
.ai-setup-card{margin-top:10px;padding:16px}
.rank-inline{display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap}
.rank-chip{display:inline-flex;align-items:center;gap:8px;padding:8px 12px;border:1px solid rgba(201,169,110,.24);background:rgba(201,169,110,.06);border-radius:999px;font-size:10px;letter-spacing:.14em;color:var(--text)}
.rank-chip b{font-family:'Cinzel',serif;font-size:13px;color:var(--gold);letter-spacing:.08em}
.rank-chip small{color:var(--muted);letter-spacing:.14em}
.ai-setup-help{font-size:10px;color:var(--muted);line-height:1.8;margin-top:10px}
.rank-ladder{display:flex;gap:8px;flex-wrap:wrap;margin-top:8px}
.rank-pill{padding:6px 10px;border-radius:999px;border:1px solid var(--border);background:rgba(255,255,255,.03);font-size:9px;color:var(--text2);letter-spacing:.12em}
.rank-pill.active{border-color:rgba(201,169,110,.34);color:var(--gold);background:rgba(201,169,110,.08)}


.wait-actions{display:flex;gap:10px;flex-wrap:wrap;justify-content:center}
.gh-room{display:none;align-items:center;justify-content:center;min-width:88px}
.mobile-utility-bar{
  position:fixed;left:12px;right:12px;bottom:calc(84px + env(safe-area-inset-bottom));z-index:118;
  display:none;grid-template-columns:repeat(5,minmax(0,1fr));gap:8px;pointer-events:none;
}
.mobile-utility-bar.show{display:grid}
.mobile-utility-btn{
