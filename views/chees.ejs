/* ══════════════════════════════════════════════════════════
   SOUND (via AudioContext)
══════════════════════════════════════════════════════════ */
let ctx=null;
function getCtx(){if(!ctx)ctx=new(window.AudioContext||window.webkitAudioContext)();return ctx;}
function beep(freq,dur,type='sine',vol=0.15){
  try{
    const c=getCtx();
    const o=c.createOscillator();
    const g=c.createGain();
    o.connect(g);g.connect(c.destination);
    o.frequency.value=freq;o.type=type;
    g.gain.setValueAtTime(vol,c.currentTime);
    g.gain.exponentialRampToValueAtTime(0.001,c.currentTime+dur);
    o.start(c.currentTime);o.stop(c.currentTime+dur);
  }catch(e){}
}
function playMove(){beep(440,0.1,'sine',0.1);setTimeout(()=>beep(550,0.08,'sine',0.07),100);}
function playCapture(){beep(220,0.15,'sawtooth',0.12);setTimeout(()=>beep(180,0.2,'sawtooth',0.08),80);}
function playJackpotSound(){
  beep(784,0.12,'triangle',0.08);
  setTimeout(()=>beep(988,0.12,'triangle',0.08),90);
  setTimeout(()=>beep(1318,0.18,'triangle',0.10),180);
  setTimeout(()=>beep(1568,0.22,'sine',0.08),310);
  setTimeout(()=>beep(1976,0.28,'sine',0.06),430);
}

