/* ══════════════════════════════════════════════════════════
   GAME OVER
══════════════════════════════════════════════════════════ */
function checkGameOver(){
  const {board,turn}=G.state;
  const st=G.state;
  if(isCheckmate(board,turn,st)){
    const winner=opp(turn);
    endGame(winner,'checkmate');
    return;
  }
  if(isStalemate(board,turn,st)){
    endGame(null,'stalemate');
    return;
  }
  const autoDraw=getAutoDrawReason(st);
  if(autoDraw){
    endGame(null,autoDraw);
    return;
  }
  if(G.timerW<=0){endGame('b','timeout');}
  else if(G.timerB<=0){endGame('w','timeout');}
}

function endGame(winner,reason){
  G.gameOver=true;
  G.roomStatus='finished';
  clearInterval(G.timerInterval);
  clearRoomMeta();
  const isWin=winner===G.playerColor;
  const isDraw=winner===null;
  const matchResult=G.mode==='self'?'draw':(isDraw?'draw':(isWin?'win':'loss'));
  let coinReward=0;
  let rankTier=null;
  if(!G.adminSandbox){
    if(G.mode==='self')recordMatchStats('draw');
    else recordMatchStats(matchResult);
    coinReward=grantCoins(matchResult);
    rankTier=updateRankAfterMatch(matchResult);
  }
  const elapsed=Math.round((Date.now()-G.startTime)/1000);
  const mm=Math.floor(elapsed/60),ss=elapsed%60;
  document.getElementById('resultPiece').textContent=isDraw?'♟':isWin?'♛':'♚';
  document.getElementById('resultTitle').textContent=G.mode==='self'?(isDraw?'Seri!':winner==='w'?`${sideName('w')} Menang!`:`${sideName('b')} Menang!`):(isDraw?'Seri!':isWin?'KEMENANGAN!':'KEKALAHAN');
  document.getElementById('resultSub').textContent=
    reason==='checkmate'?'Skakmat! Raja tak punya jalan keluar.'
    :reason==='stalemate'?'Remis: jalan buntu — tidak ada gerak yang mungkin.'
    :reason==='repetition'?'Remis: posisi yang sama terjadi 3 kali.'
    :reason==='fifty_move'?'Remis: 50 langkah tanpa pion bergerak atau capture.'
    :reason==='insufficient'?'Remis: material tidak cukup untuk skakmat.'
    :reason==='draw'?'Remis disepakati.'
    :reason==='timeout'?'Waktu habis!'
    :reason==='resign'?'Penyerahan diri.'
    :'Permainan selesai.';
  if(rankTier){
    const ladderLabel=(G.mode==='online'&&G.onlineRanked)?'Ranked PvP':'Ranked';
    document.getElementById('resultSub').textContent += ` ${ladderLabel} update: ${rankTier.name}.`;
    syncAiSetupUI();
  }
  if(coinReward>0){
    document.getElementById('resultSub').textContent += ` Coin +${coinReward}.`;
  }
  document.getElementById('rsMoves').textContent=G.moveCount;
  document.getElementById('rsCaptures').textContent=G.captureCount;
  document.getElementById('rsTime').textContent=`${mm}:${String(ss).padStart(2,'0')}`;
  document.getElementById('rsCoins').textContent=`+${coinReward}`;
  setTimeout(()=>showScreen('resultScreen'),1200);
}

async function resignGame(){
  if(G.gameOver)return;
  if(!confirm('Yakin menyerah?'))return;
  endGame(opp(G.mode==='self'?G.state.turn:G.playerColor),'resign');
  if(G.mode==='online')await syncOnlineMove();
}

async function offerDraw(){
  if(G.gameOver)return;
  if(G.mode==='ai'){
    if(Math.random()<0.3){endGame(null,'draw');addChatMsg('system','AI menerima seri.');}
    else addChatMsg('system','AI menolak seri. Terus berjuang!');
  } else if(G.mode==='self') {
    endGame(null,'draw');
  } else {
    addChatMsg('system','Tawaran seri dikirim...');
    if(confirm('Paksa seri untuk room custom testing ini?')){endGame(null,'draw');await syncOnlineMove();}
  }
}

