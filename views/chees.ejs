function applyTurnStartEffects(){
  const color=G.state.turn;
  let next=decayBoardStatuses({...G.state,hp:{w:100,b:100},debuffs:{w:[],b:[]}},color);
  next=tickCooldownAtTurnStart(next,color);
  G.state=next;
}
