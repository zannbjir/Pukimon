function activateSkill(requestedColor){
  if(G.gameOver)return;
  const color=G.mode==='self'?(requestedColor||G.state.turn):G.playerColor;
  if(G.mode==='self'&&color!==G.state.turn){showToast(`Sekarang giliran ${G.state.turn==='w'?'White':'Black'}.`);return;}
  if(G.mode!=='self'&&color!==G.playerColor){showToast('Kamu tidak bisa pakai skill lawan.');return;}
  if(inCheck(G.state.board,color)){showToast('Skill tidak bisa dipakai saat Raja sedang skak.');return;}
  const blockedReason=skillBlockedReason(color);
  if(blockedReason){showToast(blockedReason);return;}
  const cd=skillRemaining(color);
  if(cd>0){showToast(`Skill masih cooldown ${cd} giliran.`);return;}
  if(skillUsesLeft(color)<=0){showToast('Skill class ini sudah mencapai batas pemakaian match ini.');return;}
  if(G.state.turn!==color){showToast('Bukan giliranmu!');return;}
  const cls=sideClass(color);
  const skill=SKILLS[cls];
  G.skillOwner=color;
  const newState=skill.apply(G.state,color);
  pulseHaptic('skill');
  if(newState!==G.state){
    if(G.skillMode===null) pushUndoSnapshot(`skill_${cls}`);
    G.state={...newState};
    if(G.skillMode===null){
      setSkillCooldown(color);
      if(skillConsumesTurn(cls))advanceTurnAfterSkill(color);
      applyTurnStartEffects();
      updatePanels();
      updateMoveHistory();
      checkGameOver();
    }
  } else if(G.skillMode===null){
    G.skillOwner=null;
  }
  updateSkillUI();
  renderBoard();
  if(!G.gameOver&&G.mode==='ai'&&G.state.turn!==G.playerColor){
    queueAiMove();
  }
}

function updateSkillUI(){
  [['w','white'],['b','black']].forEach(([color,prefix])=>{
    const card=document.getElementById(`${prefix}SkillCard`);
    const badge=document.getElementById(`${prefix}SkillBadge`);
    const cd=skillRemaining(color);
    const usesLeft=skillUsesLeft(color);
    const blockedByCheck=inCheck(G.state.board,color);
    const blockedReason=skillBlockedReason(color);
    const active=!!G.skillMode&&G.skillOwner===color;
    card.classList.toggle('used',cd>0||usesLeft<=0||blockedByCheck||!!blockedReason);
    if(blockedByCheck) badge.textContent='IN CHECK';
    else if(blockedReason) badge.textContent='NO TARGET';
    else if(cd>0)badge.textContent=`CD ${cd}T`;
    else if(Number.isFinite(usesLeft) && usesLeft<=0) badge.textContent='LIMIT';
    else if(Number.isFinite(usesLeft) && usesLeft<99) badge.textContent=`${usesLeft} LEFT`;
    else badge.textContent=color==='w'?'CLICK TO USE':'READY';
    card.classList.toggle('usable',G.mode==='self'||(color===G.playerColor&&G.mode!=='self'));
    card.classList.toggle('activated',active);
  });
  const cancelBtn=document.getElementById('cancelSkillBtn');
  if(cancelBtn) cancelBtn.style.display=G.skillMode?'inline-flex':'none';
  const mobileCancel=document.getElementById('mobileCancelSkillBtn');
  if(mobileCancel) mobileCancel.style.display=G.skillMode?'inline-flex':'none';
  updateSkillDock();
}

function updateSkillDock(){
  const dock=document.getElementById('skillDock');
  if(!dock||!G.state){return;}
  dock.classList.remove('show');
}

function updateMobileBattleHud(){
  if(!G.state)return;
  if(!document.getElementById('mobileTopName') || !document.getElementById('mobileBottomName')) return;
  const enemy=G.playerColor==='w'?'b':'w';
  const mine=G.playerColor;
  const topColor=G.mode==='self'?'b':enemy;
  const bottomColor=G.mode==='self'?'w':mine;
  const syncBar=(prefix,color)=>{
    document.getElementById(`${prefix}Name`).textContent=`${sideName(color)} · ${getClassLabel(sideClass(color))}`;
    const hpNum=document.getElementById(`${prefix}HpNum`); if(hpNum) hpNum.textContent='—';
    const fill=document.getElementById(`${prefix}HpFill`); if(fill){ fill.style.width='100%'; fill.classList.remove('low'); }
    const states=[];
    if(G.state.turn===color) states.push(G.mode==='self' ? 'Acting' : (color===G.playerColor?'Your turn':'Enemy turn'));
    else states.push('Waiting');
    const cd=skillRemaining(color);
    states.push(cd>0?`Skill CD ${cd}`:'Skill ready');
    const protectedPiece = G.shieldedPiece && G.shieldedPiece.color===color;
    if(protectedPiece) states.push('🛡 Shield');
    let immortalCount=0,jackpotCount=0;
    for(let r=0;r<8;r++)for(let f=0;f<8;f++){
      const p=G.state.board[r][f];
      if(p&&p.c===color&&p.immortalTurns)immortalCount++;
      if(p&&p.c===color&&p.jackpotTurns)jackpotCount++;
    }
    if(immortalCount) states.push(`♾ ${immortalCount} immortal`);
    if(jackpotCount) states.push(`🎰 ${jackpotCount} jackpot`);
    const captured = color==='w' ? G.state.capturedB.length : G.state.capturedW.length;
    states.push(`☠ ${captured} captured`);
    document.getElementById(`${prefix}State`).innerHTML=states.map(s=>`<span>${s}</span>`).join('');
  };
  syncBar('mobileTop',topColor);
  syncBar('mobileBottom',bottomColor);

  const syncSkillBtn=(btnPrefix,color,show)=>{
    const btn=document.getElementById(`${btnPrefix}Skill`);
    const title=document.getElementById(`${btnPrefix}SkillTitle`);
    const sub=document.getElementById(`${btnPrefix}SkillSub`);
    if(!btn || !title || !sub) return;
    if(!show){ btn.style.display='none'; return; }
    const cls=sideClass(color);
    const info=CLASS_INFO[cls] || {label:'Skill',icon:'⚡',short:'Use skill'};
    const cd=skillRemaining(color);
    const active=!!G.skillMode && G.skillOwner===color;
    const blockedByCheck=inCheck(G.state.board,color);
    const blockedReason=skillBlockedReason(color);
    btn.style.display='flex';
    btn.disabled = G.gameOver || cd>0 || blockedByCheck || !!blockedReason || G.state.turn!==color || (G.mode!=='self' && color!==G.playerColor);
    title.textContent=`${info.icon} ${info.label}`;
    const shortGuide=(CLASS_INFO[cls]?.short||'Use skill').replace(/\.$/,'');
    const usesLeft=skillUsesLeft(color);
    const usesTag=(Number.isFinite(usesLeft) && usesLeft<99) ? ` · ${usesLeft} left` : '';
    if(active) sub.textContent='Choose target';
    else if(blockedByCheck) sub.textContent='King in check';
    else if(blockedReason) sub.textContent=blockedReason.replace('Tidak ada ','No ').replace(' tersisa.',' left');
    else if(cd>0) sub.textContent=`CD ${cd} · ${shortGuide}${usesTag}`;
    else if(Number.isFinite(usesLeft) && usesLeft<=0) sub.textContent='Match limit reached';
    else if(btn.disabled) sub.textContent=(G.state.turn===color ? `${shortGuide}${usesTag}` : 'Wait turn');
    else sub.textContent=`${shortGuide}${usesTag}`;
  };
  syncSkillBtn('mobileBottom',bottomColor,true);
  syncSkillBtn('mobileTop',topColor,G.mode==='self');
}


