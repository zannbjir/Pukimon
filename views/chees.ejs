function refreshDisplayedClassUI(){
  if(!G.state) return;
  const whiteClass=sideClass('w');
  const blackClass=sideClass('b');
  const whiteSkill=SKILLS[whiteClass] || SKILLS.king;
  const blackSkill=SKILLS[blackClass] || SKILLS.queen;
  const applySide=(prefix,color,cls,skill)=>{
    const nameEl=document.getElementById(`${prefix}Name`);
    const classEl=document.getElementById(`${prefix}Class`);
    const pieceEl=document.getElementById(`${prefix}Piece`);
    const skillIcon=document.getElementById(`${prefix}SkillIcon`);
    const skillName=document.getElementById(`${prefix}SkillName`);
    const skillDesc=document.getElementById(`${prefix}SkillDesc`);
    const card=document.getElementById(`${prefix}SkillCard`);
    if(nameEl) nameEl.textContent=sideName(color);
    if(classEl) classEl.textContent=classTitle(cls);
    if(pieceEl) pieceEl.textContent=skill.icon;
    if(skillIcon) skillIcon.textContent=skill.icon;
    if(skillName) skillName.textContent=skill.name;
    if(skillDesc) skillDesc.textContent=skill.desc;
    if(card) card.style.setProperty('--skill-col', skill.col);
  };
  applySide('white','w',whiteClass,whiteSkill);
  applySide('black','b',blackClass,blackSkill);
}

function canUseUndo(){
  if(G.gameOver || G.mode==='online') return false;
  if(G.mode==='self') return (G.undoStack||[]).length>0;
  if(G.mode==='ai' && !G.rankMode && (G.aiDifficulty||'beginner')==='beginner') return (G.undoStack||[]).length>0;
  return false;
}

function pushUndoSnapshot(reason=''){
  if(G.mode==='online') return;
  if(G.mode==='ai' && (G.rankMode || (G.aiDifficulty||'beginner')!=='beginner')) return;
  const snap={
    reason,
    state: JSON.parse(JSON.stringify(G.state)),
    timerW:G.timerW,
    timerB:G.timerB,
    moveCount:G.moveCount,
    captureCount:G.captureCount,
    lastMove:G.lastMove ? JSON.parse(JSON.stringify(G.lastMove)) : null,
    selected:G.selected ? [...G.selected] : null,
    legalMovesCache: JSON.parse(JSON.stringify(G.legalMovesCache||[])),
    shieldedPiece:G.shieldedPiece ? JSON.parse(JSON.stringify(G.shieldedPiece)) : null,
    skillMode:G.skillMode,
    leapKnight:G.leapKnight ? [...G.leapKnight] : null,
    rookShiftFrom:G.rookShiftFrom ? [...G.rookShiftFrom] : null,
    skillOwner:G.skillOwner
  };
  G.undoStack=[snap];
  updateUndoButton();
}

function undoLastAction(){
  if(!canUseUndo()){ showToast('Undo tidak tersedia untuk mode ini.'); return; }
  const snap=(G.undoStack||[]).pop();
  if(!snap){ showToast('Belum ada aksi yang bisa di-undo.'); return; }
  clearTimeout(G.aiTimer); clearTimeout(G.aiWatchdog);
  G.aiThinking=false;
  G.state=JSON.parse(JSON.stringify(snap.state));
  G.timerW=snap.timerW;
  G.timerB=snap.timerB;
  G.moveCount=snap.moveCount;
  G.captureCount=snap.captureCount;
  G.lastMove=snap.lastMove;
  G.selected=snap.selected;
  G.legalMovesCache=snap.legalMovesCache||[];
  G.shieldedPiece=snap.shieldedPiece;
  G.skillMode=null;
  G.leapKnight=null;
  G.rookShiftFrom=null;
  G.skillOwner=null;
  renderBoard();
  renderTimers();
  refreshDisplayedClassUI();
  updatePanels();
  updateMoveHistory();
  updateSkillUI();
  updateStatus();
  refreshJackpotVignette();
  showToast('↶ Undo berhasil.');
  updateUndoButton();
}

