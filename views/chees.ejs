  beginner:{label:'Beginner',depth:1,maxMoves:8,randomness:0.56,skillChance:0.18,minSkillScore:500,delay:[260,420]},
  casual:{label:'Casual',depth:2,maxMoves:12,randomness:0.28,skillChance:0.44,minSkillScore:320,delay:[200,320]},
  standard:{label:'Standard',depth:2,maxMoves:18,randomness:0.12,skillChance:0.70,minSkillScore:220,delay:[140,240]}
};
const AI_PERSONAS={
  wild:{label:'Wild',captureBias:24,centerBias:8,knightBias:16,rookBias:4,pawnBias:8,randomBoost:.14},
  greedy:{label:'Greedy',captureBias:36,centerBias:4,knightBias:4,rookBias:10,pawnBias:6,randomBoost:.08},
  tricky:{label:'Tricky',captureBias:18,centerBias:12,knightBias:18,rookBias:0,pawnBias:5,randomBoost:.18},
  fortress:{label:'Fortress',captureBias:14,centerBias:6,knightBias:2,rookBias:18,pawnBias:4,randomBoost:.10},
  swarm:{label:'Swarm',captureBias:16,centerBias:10,knightBias:6,rookBias:2,pawnBias:16,randomBoost:.16}
};
function pickRandomAiPersona(diff='beginner'){
  const pools={
    beginner:['wild','swarm','tricky'],
    casual:['wild','greedy','tricky','fortress','swarm'],
    standard:['greedy','tricky','fortress','swarm']
  };
  const source=(pools[diff]||pools.beginner);
  const key=source[Math.floor(Math.random()*source.length)];
  return {key,...AI_PERSONAS[key]};
}
function readRankState(){
  try{
    const raw=localStorage.getItem(STORAGE_RANK_KEY);
    if(raw){
      const data=JSON.parse(raw);
      if(typeof data.points==='number') return {...{points:0,wins:0,losses:0,draws:0},...data};
    }
  }catch(e){}
  return {points:0,wins:0,losses:0,draws:0};
}
function writeRankState(data){
  try{localStorage.setItem(STORAGE_RANK_KEY,JSON.stringify(data));}catch(e){}
}
function getRankTier(points){
  return RANK_TIERS.find(t=>points>=t.min&&points<=t.max) || RANK_TIERS[0];
}
function getCurrentRankTier(){
  return getRankTier(readRankState().points||0);
}
function getSelectedAiMode(){
  return document.getElementById('aiModeSel')?.value || 'casual';
}
function getSelectedAiDifficulty(){
  return document.getElementById('aiDifficultySel')?.value || 'beginner';
}
function currentAiPreset(){
  const mode=getSelectedAiMode?.()||'casual';
  const diff=(G.rankMode && !G.onlineRanked)
    ? (G.rankTierDifficulty||getCurrentRankTier().difficulty)
    : (G.aiDifficulty||getSelectedAiDifficulty());
  return AI_PRESETS[diff] || AI_PRESETS.beginner;
}

function pickRandomAiClass(diff, myClass=''){
  const pools={
    beginner:['king','bishop','knight','rook','pawn','warlock'],
    casual:['king','bishop','knight','rook','pawn','warlock','necromancer'],
    standard:['king','queen','bishop','knight','rook','pawn','warlock','necromancer']
  };
  let pool=[...(pools[diff]||pools.beginner)];
  if(pool.length>2 && myClass) pool=pool.filter(c=>c!==myClass);
  return pool[Math.floor(Math.random()*pool.length)] || 'knight';
}

function syncAiSetupUI(){
  const modeSel=document.getElementById('aiModeSel');
  const diffWrap=document.getElementById('aiDifficultyWrap');
  const help=document.getElementById('aiSetupHelp');
  const primaryBtn=document.getElementById('primaryModeBtn');
  const rank=readRankState();
  const tier=getRankTier(rank.points||0);
  document.getElementById('rankTierLabel').textContent=tier.name;
  document.getElementById('rankPointsLabel').textContent=String(rank.points||0);
  document.querySelectorAll('[data-rank-pill]').forEach(el=>el.classList.toggle('active',el.dataset.rankPill===tier.name));
  const mode=modeSel?.value || 'casual';
  const rankedAi=(mode==='ranked_ai');
  const rankedPvp=(mode==='ranked_pvp');
  if(diffWrap) diffWrap.style.opacity=(rankedAi||rankedPvp)?'.55':'1';
  if(diffWrap) diffWrap.style.pointerEvents=(rankedAi||rankedPvp)?'none':'auto';
  if(primaryBtn){
    primaryBtn.textContent = rankedPvp ? '🏆 Cari Match' : '⚔ VS Komputer';
  }
  if(help){
    if(rankedAi){
      help.textContent=`Ranked Ladder (AI) aktif. Tier kamu ${tier.name}; AI memakai profil ${AI_PRESETS[tier.difficulty].label}. Menang +24 RP, seri +8 RP, kalah -16 RP.`;
    }else if(rankedPvp){
      help.textContent=`Ranked Matchmaking aktif. Sistem akan mencari pemain lain dengan tier ${tier.name}. Menang +28 RP, seri +10 RP, kalah -18 RP.`;
    }else{
      help.textContent='Beginner cocok untuk pemula: AI lebih sering salah, lebih jarang pakai skill, dan berpikir lebih cepat.';
      if(getSelectedAiDifficulty()==='casual') help.textContent='Casual cukup santai: masih ramah pemula, tapi lebih rapi dari Beginner.';
      if(getSelectedAiDifficulty()==='standard') help.textContent='Standard paling menantang untuk mode santai. Pakai ini kalau Beginner terasa terlalu mudah.';
    }
  }
}
function updateRankAfterMatch(result){
  if(!((G.mode==='ai' && G.rankMode) || (G.mode==='online' && G.onlineRanked))) return null;
  const rank=readRankState();
  if(G.mode==='online' && G.onlineRanked){
    if(result==='win'){ rank.points+=28; rank.wins=(rank.wins||0)+1; }
    else if(result==='loss'){ rank.points=Math.max(0,(rank.points||0)-18); rank.losses=(rank.losses||0)+1; }
    else { rank.points+=10; rank.draws=(rank.draws||0)+1; }
  }else{
    if(result==='win'){ rank.points+=24; rank.wins=(rank.wins||0)+1; }
    else if(result==='loss'){ rank.points=Math.max(0,(rank.points||0)-16); rank.losses=(rank.losses||0)+1; }
    else { rank.points+=8; rank.draws=(rank.draws||0)+1; }
  }
  writeRankState(rank);
  return getRankTier(rank.points||0);
}
function protectedCoords(){
  const arr=[];
  if(G.shieldedPiece) arr.push([G.shieldedPiece.r,G.shieldedPiece.f,G.shieldedPiece.color]);
  return arr;
}
function isMoveBlockedByProtection(state,fromR,fromF,toR,toF){
  const attacker=state.board[fromR]?.[fromF];
  const target=state.board[toR]?.[toF];
  if(!attacker || !target || attacker.c===target.c) return false;
  if(target.immortalTurns || target.jackpotTurns) return true;
  if(G.shieldedPiece && G.shieldedPiece.r===toR && G.shieldedPiece.f===toF && G.shieldedPiece.color===target.c) return true;
  return false;
}
function actionableMoves(state,color){
  return allLegalMoves(state.board,color,state).filter(mv=>{
    const piece=state.board[mv.from[0]]?.[mv.from[1]];
    if(!piece) return false;
    if(piece.locked && !piece.jackpotTurns) return false;
    if(isMoveBlockedByProtection(state,mv.from[0],mv.from[1],mv.to[0],mv.to[1])) return false;
    return true;
  });
}

function boardStateToken(state){
  const rows=[];
  for(let r=0;r<8;r++){
    const cols=[];
    for(let f=0;f<8;f++){
      const p=state.board[r][f];
      if(!p){ cols.push('..'); continue; }
      cols.push(`${p.c}${p.t}${p.m?'1':'0'}${p.locked||0}${p.immortalTurns||0}${p.jackpotTurns||0}`);
    }
    rows.push(cols.join(','));
  }
  const castling=`${state.castling?.w?.k?1:0}${state.castling?.w?.q?1:0}${state.castling?.b?.k?1:0}${state.castling?.b?.q?1:0}`;
  const ep=state.ep?`${state.ep[0]}${state.ep[1]}`:'--';
  const relic=state.powerup?`${state.powerup.type}@${state.powerup.r}${state.powerup.f}${state.powerup.spawnedBy||''}`:'none';
  return `${rows.join('/')}|${state.turn}|${castling}|${ep}|${relic}`;
}
function registerPositionState(state){
  const key=boardStateToken(state);
  const counts={...(state.positionCounts||{})};
  counts[key]=(counts[key]||0)+1;
  return {...state,lastPositionKey:key,positionCounts:counts};
}
function hasInsufficientMaterial(board){
  const minors={w:[],b:[]};
  for(let r=0;r<8;r++)for(let f=0;f<8;f++){
    const p=board[r][f];
    if(!p) continue;
    if(['P','Q','R'].includes(p.t)) return false;
    if(p.t==='B') minors[p.c].push({t:'B',square:(r+f)%2});
    else if(p.t==='N') minors[p.c].push({t:'N'});
    else if(p.t!=='K') return false;
  }
  const white=minors.w, black=minors.b;
  const total=white.length+black.length;
  if(total===0) return true;
  if(total===1) return true;
  if(total===2){
    const wB=white.length===1&&white[0].t==='B';
    const bB=black.length===1&&black[0].t==='B';
    if(wB&&bB&&white[0].square===black[0].square) return true;
  }
  return false;
}
function getAutoDrawReason(state){
  if(hasInsufficientMaterial(state.board)) return 'insufficient';
  if((state.halfmoveClock||0)>=100) return 'fifty_move';
  const key=state.lastPositionKey||boardStateToken(state);
  if((state.positionCounts?.[key]||0)>=3) return 'repetition';
  return null;
}

/* ══════════════════════════════════════════════════════════
   AI — MINIMAX ALPHA-BETA DEPTH 3
══════════════════════════════════════════════════════════ */
const POS_BONUS={
  P:[[0,0,0,0,0,0,0,0],[50,50,50,50,50,50,50,50],[10,10,20,30,30,20,10,10],
     [5,5,10,25,25,10,5,5],[0,0,0,20,20,0,0,0],[5,-5,-10,0,0,-10,-5,5],
     [5,10,10,-20,-20,10,10,5],[0,0,0,0,0,0,0,0]],
  N:[[-50,-40,-30,-30,-30,-30,-40,-50],[-40,-20,0,0,0,0,-20,-40],
     [-30,0,10,15,15,10,0,-30],[-30,5,15,20,20,15,5,-30],
     [-30,0,15,20,20,15,0,-30],[-30,5,10,15,15,10,5,-30],
     [-40,-20,0,5,5,0,-20,-40],[-50,-40,-30,-30,-30,-30,-40,-50]],
  B:[[-20,-10,-10,-10,-10,-10,-10,-20],[-10,0,0,0,0,0,0,-10],
     [-10,0,5,10,10,5,0,-10],[-10,5,5,10,10,5,5,-10],
     [-10,0,10,10,10,10,0,-10],[-10,10,10,10,10,10,10,-10],
     [-10,5,0,0,0,0,5,-10],[-20,-10,-10,-10,-10,-10,-10,-20]],
  R:[[0,0,0,0,0,0,0,0],[5,10,10,10,10,10,10,5],[-5,0,0,0,0,0,0,-5],
     [-5,0,0,0,0,0,0,-5],[-5,0,0,0,0,0,0,-5],[-5,0,0,0,0,0,0,-5],
     [-5,0,0,0,0,0,0,-5],[0,0,0,5,5,0,0,0]],
  Q:[[-20,-10,-10,-5,-5,-10,-10,-20],[-10,0,0,0,0,0,0,-10],
     [-10,0,5,5,5,5,0,-10],[-5,0,5,5,5,5,0,-5],
     [0,0,5,5,5,5,0,-5],[-10,5,5,5,5,5,0,-10],
     [-10,0,5,0,0,0,0,-10],[-20,-10,-10,-5,-5,-10,-10,-20]],
  K:[[-30,-40,-40,-50,-50,-40,-40,-30],[-30,-40,-40,-50,-50,-40,-40,-30],
     [-30,-40,-40,-50,-50,-40,-40,-30],[-30,-40,-40,-50,-50,-40,-40,-30],
     [-20,-30,-30,-40,-40,-30,-30,-20],[-10,-20,-20,-20,-20,-20,-20,-10],
     [20,20,0,0,0,0,20,20],[20,30,10,0,0,10,30,20]]
};

function evalBoard(board){
  let score=0;
  for(let r=0;r<8;r++)
    for(let f=0;f<8;f++){
      const p=board[r][f];
      if(!p)continue;
      const v=PVAL[p.t];
      const pr=p.c==='w'?r:7-r;
      const pos=POS_BONUS[p.t]?POS_BONUS[p.t][7-pr][f]:0;
      score+=(p.c==='w'?1:-1)*(v+pos);
    }
  return score;
}

function minimax(board,state,depth,alpha,beta,isMax){
  const color=isMax?'w':'b';
  if(isCheckmate(board,color,state))return isMax?-50000:50000;
  if(isStalemate(board,color,state))return 0;
  if(depth===0)return evalBoard(board);
  const moves=orderMoves(state,color,actionableMoves(state,color));
  if(isMax){
    let best=-Infinity;
    for(const mv of moves){
      const ns=applyMove(state,...mv.from,...mv.to);
      best=Math.max(best,minimax(ns.board,ns,depth-1,alpha,beta,false));
      alpha=Math.max(alpha,best);
      if(beta<=alpha)break;
    }
    return best;
  } else {
    let best=Infinity;
    for(const mv of moves){
      const ns=applyMove(state,...mv.from,...mv.to);
      best=Math.min(best,minimax(ns.board,ns,depth-1,alpha,beta,true));
      beta=Math.min(beta,best);
      if(beta<=alpha)break;
    }
    return best;
  }
}

function moveTacticalScore(state,mv,color){
  const fromPiece=state.board[mv.from[0]][mv.from[1]];
  const target=state.board[mv.to[0]][mv.to[1]];
  let score=0;
  if(target) score += (PVAL[target.t]||0) - ((PVAL[fromPiece?.t]||0)*0.08);
  const ns=applyMove(state,...mv.from,...mv.to);
  if(inCheck(ns.board,opp(color))) score += 55;
  if(fromPiece?.t==='P' && (mv.to[0]===0 || mv.to[0]===7)) score += 90;
  if([3,4].includes(mv.to[0]) && [3,4].includes(mv.to[1])) score += 10;
  const moved=ns.board[mv.to[0]][mv.to[1]];
  if(moved && isAttacked(ns.board,mv.to[0],mv.to[1],opp(color))) score -= (PVAL[moved.t]||0)*0.18;
  if(color==='b' && G.mode==='ai' && G.aiPersona){
    const style=G.aiPersona;
    if(target) score += style.captureBias||0;
    if([2,3,4,5].includes(mv.to[0]) && [2,3,4,5].includes(mv.to[1])) score += style.centerBias||0;
    if(fromPiece?.t==='N') score += style.knightBias||0;
    if(fromPiece?.t==='R') score += style.rookBias||0;
    if(fromPiece?.t==='P') score += style.pawnBias||0;
    if(Math.abs(mv.to[0]-mv.from[0])+Math.abs(mv.to[1]-mv.from[1])>=4) score += (style.randomBoost||0)*100*Math.random();
  }
  return score;
}

function orderMoves(state,color,moves){
  return [...moves].sort((a,b)=>moveTacticalScore(state,b,color)-moveTacticalScore(state,a,color));
}

function getBestMove(state,color='b'){
  const preset=currentAiPreset();
  const baseMoves=actionableMoves(state,color);
  if(!baseMoves.length)return null;
  const moves=orderMoves(state,color,baseMoves);
  const maximizing=color==='w';
  const depth=Math.max(1,preset.depth||1);
  let best=maximizing?-Infinity:Infinity,bestMove=moves[0];
  const scored=[];
  for(const mv of moves.slice(0, Math.min(moves.length, preset.maxMoves||12))){
    const ns=applyMove(state,...mv.from,...mv.to);
    const score=minimax(ns.board,ns,depth-1,-Infinity,Infinity,!maximizing);
    scored.push({mv,score});
    if(maximizing){
      if(score>best){best=score;bestMove=mv;}
    }else{
      if(score<best){best=score;bestMove=mv;}
    }
  }
  if(!scored.length) return bestMove;
  scored.sort((a,b)=> maximizing ? b.score-a.score : a.score-b.score);
  const earlyPhase=(G.moveCount||0)<10;
  const topPool=scored.slice(0, Math.min(scored.length, earlyPhase?6:5));
  const styleBoost=(color==='b' && G.mode==='ai' && G.aiPersona) ? (G.aiPersona.randomBoost||0) : 0;
  const randChance=Math.min(0.86,(preset.randomness||0)+styleBoost+(earlyPhase?0.14:0));
  if(Math.random() < randChance && topPool.length>1){
    const biased=topPool.slice(0, Math.min(topPool.length, earlyPhase?5:4));
    const idx=Math.floor(Math.random()*biased.length);
    return biased[idx].mv;
  }
  return topPool[0].mv;
}

