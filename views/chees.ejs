function startTimer(){
  clearInterval(G.timerInterval);
  G.timerInterval=setInterval(()=>{
    if(G.gameOver)return;
    if(G.state.turn==='w')G.timerW=Math.max(0,G.timerW-1);
    else G.timerB=Math.max(0,G.timerB-1);
    renderTimers();
    if(G.timerW===0||G.timerB===0)checkGameOver();
  },1000);
}

function renderTimers(){
  ['w','b'].forEach(c=>{
    const t=c==='w'?G.timerW:G.timerB;
    const el=document.getElementById(c==='w'?'timerWhite':'timerBlack');
    const mm=Math.floor(t/60),ss=t%60;
    el.textContent=`${mm}:${String(ss).padStart(2,'0')}`;
    el.classList.toggle('active-timer',G.state.turn===c&&!G.gameOver);
    el.classList.toggle('low-time',t<30);
  });
}

