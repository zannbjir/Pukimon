function getClassLabel(cls){
  const key=String(cls||'').trim().toLowerCase();
  return CLASS_INFO[key]?.label || 'Pejuang';
}

function skillCooldownForClass(cls){
  const key=String(cls||'').trim().toLowerCase();
  return CLASS_INFO[key]?.cooldown ?? 8;
}

function skillMaxUsesForClass(cls){
  const key=String(cls||'').trim().toLowerCase();
  const raw=CLASS_INFO[key]?.maxUses;
  return Number.isFinite(raw) ? raw : Infinity;
}

function hasPieceTypeAlive(color,type,state=G.state){
  const board=state?.board || [];
  for(let r=0;r<8;r++) for(let f=0;f<8;f++){
    const p=board[r]?.[f];
    if(p && p.c===color && p.t===type) return true;
  }
  return false;
}

function skillBlockedReason(color,state=G.state){
  const cls=sideClass(color);
  if(cls==='knight' && !hasPieceTypeAlive(color,'N',state)) return 'Tidak ada Rider tersisa.';
  if(cls==='rook' && !hasPieceTypeAlive(color,'R',state)) return 'Tidak ada Citadel tersisa.';
  return '';
}

function skillUsesCount(color,state=G.state){
  return Number(state?.skills?.[color]?.uses || 0);
}

function skillUsesLeft(color,state=G.state){
  const max=skillMaxUsesForClass(sideClass(color));
  if(!Number.isFinite(max)) return Infinity;
  return Math.max(0, max - skillUsesCount(color,state));
}

function skillRemaining(color,state=G.state){
  const slot=state?.skills?.[color] || {};
  if(typeof slot.cooldown==='number') return Math.max(0, slot.cooldown);
  return slot.used ? 99 : 0;
}

function setSkillCooldown(color, turns){
  const slot={...(G.state.skills[color]||{})};
  G.state.skills[color]={
    ...slot,
    cooldown: Math.max(0, turns ?? skillCooldownForClass(sideClass(color))),
    uses: (slot.uses||0)+1
  };
}

function tickCooldownAtTurnStart(state,color){
  const skills={...(state.skills||{})};
  const slot={...(skills[color]||{cooldown:0,uses:0})};
  if(typeof slot.cooldown!=='number') slot.cooldown = slot.used ? 99 : 0;
  if(slot.cooldown>0) slot.cooldown--;
  skills[color]=slot;
  return {...state,skills};
}

function readStats(){
  try{
    const raw=localStorage.getItem(STORAGE_STATS_KEY);
    if(raw)return JSON.parse(raw);
  }catch(e){}
  return {wins:0,losses:0,draws:0,totalMatches:0,customMatches:0,classUsage:{king:0,queen:0,bishop:0,knight:0,rook:0,pawn:0,warlock:0,necromancer:0}};
}

function writeStats(stats){
  try{localStorage.setItem(STORAGE_STATS_KEY,JSON.stringify(stats));}catch(e){}
}


function readWallet(){
  try{
    const raw=localStorage.getItem(STORAGE_WALLET_KEY);
    if(raw){
      const parsed=JSON.parse(raw);
      return {coins:Number(parsed.coins||0),earned:Number(parsed.earned||0),spent:Number(parsed.spent||0),owned:Array.isArray(parsed.owned)?parsed.owned:[]};
    }
  }catch(e){}
  return {coins:0,earned:0,spent:0,owned:[]};
}
function writeWallet(wallet){
  try{localStorage.setItem(STORAGE_WALLET_KEY,JSON.stringify(wallet));}catch(e){}
}
function getCoinReward(result){
  if(G.mode==='self') return 0;
  const ranked=(G.rankMode || (G.mode==='online'&&G.onlineRanked));
  const online=(G.mode==='online');
  if(result==='win') return ranked ? (online ? 140 : 110) : (online ? 95 : 70);
  if(result==='draw') return ranked ? 48 : 36;
  return ranked ? 24 : 16;
}
function grantCoins(result){
  const reward=getCoinReward(result);
  const wallet=readWallet();
  wallet.coins=(wallet.coins||0)+reward;
  wallet.earned=(wallet.earned||0)+reward;
  writeWallet(wallet);
  return reward;
}

function recordMatchStats(result){
  const stats=readStats();
  stats.classUsage=stats.classUsage||{king:0,queen:0,bishop:0,knight:0,rook:0,pawn:0,warlock:0,necromancer:0};
  if(G.mode==='self'){
    stats.customMatches=(stats.customMatches||0)+1;
    writeStats(stats);
    return;
  }
  stats.totalMatches=(stats.totalMatches||0)+1;
  stats.classUsage[G.myClass]=(stats.classUsage[G.myClass]||0)+1;
  if(result==='win')stats.wins=(stats.wins||0)+1;
  else if(result==='loss')stats.losses=(stats.losses||0)+1;
  else stats.draws=(stats.draws||0)+1;
  writeStats(stats);
}

