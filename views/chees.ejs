}
.global-ui-btn{
  border:1px solid var(--border2);background:rgba(15,15,15,.92);color:var(--text);
  padding:8px 12px;border-radius:12px;cursor:pointer;font:600 10px 'DM Mono',monospace;letter-spacing:.12em;
  backdrop-filter:blur(10px);
}
html[data-theme="light"] .global-ui-btn{background:rgba(255,255,255,.92)}
.turn-center-banner{
  position:fixed;left:50%;top:50%;transform:translate(-50%,-50%) scale(.985);
  min-width:min(82vw,300px);max-width:84vw;padding:12px 16px;border-radius:14px;
  border:1px solid rgba(201,169,110,.16);background:rgba(10,10,10,.72);z-index:140;
