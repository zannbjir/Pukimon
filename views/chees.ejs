function isMobileViewport(){
  return window.matchMedia('(max-width: 900px)').matches;
}

function loadMobilePrefs(){
  try{
    const raw=localStorage.getItem(STORAGE_MOBILE_PREFS_KEY);
    G.mobilePrefs={haptics:true,...(raw?JSON.parse(raw):{})};
  }catch(e){
    G.mobilePrefs={haptics:true};
  }
}

function saveMobilePrefs(){
  try{ localStorage.setItem(STORAGE_MOBILE_PREFS_KEY,JSON.stringify(G.mobilePrefs||{haptics:true})); }catch(e){}
}


function loadTheme(){
  let theme='dark';
  try{
    const raw=localStorage.getItem(STORAGE_THEME_KEY);
    if(raw==='light' || raw==='dark') theme=raw;
  }catch(e){}
  applyTheme(theme,false);
}

function applyTheme(theme,announce=true){
  const next=theme==='light'?'light':'dark';
  document.documentElement.setAttribute('data-theme',next);
  const label=next==='light'?'🌙 Dark':'☀ Light';
  const compact=next==='light'?'Dark':'Light';
  const headerBtn=document.getElementById('headerThemeBtn');
  const globalBtn=document.getElementById('globalThemeBtn');
  const mobileLabel=document.getElementById('mobileThemeLabel');
  if(headerBtn) headerBtn.textContent=label;
  if(globalBtn) globalBtn.textContent=label.toUpperCase();
  if(mobileLabel) mobileLabel.textContent=compact;
  try{ localStorage.setItem(STORAGE_THEME_KEY,next); }catch(e){}
  if(announce) showToast(`Tema ${next==='light'?'Simple Light':'Simple Dark'} aktif.`);
}

function toggleTheme(){
  const current=document.documentElement.getAttribute('data-theme')==='light'?'light':'dark';
  applyTheme(current==='light'?'dark':'light');
  pulseHaptic('tap');
}

function pulseHaptic(kind='tap'){
  if(!G.mobilePrefs?.haptics || !('vibrate' in navigator))return;
  const patterns={tap:12,move:[10],capture:[18,24,18],skill:[18,22,30],alert:[24,30,24],success:[12,20,40],jackpot:[30,50,30,70,40]};
  try{ navigator.vibrate(patterns[kind]||10); }catch(e){}
}

function updateRoomCodeButtons(){
  const code=G.onlineRanked ? '' : String(G.roomCode||'').trim();
  const header=document.getElementById('roomCodeBtn');
  const mobile=document.getElementById('mobileRoomBtn');
  const label=document.getElementById('mobileRoomBtnLabel');
  const helpMeta=document.getElementById('helpRoomMeta');
  if(header){
    header.textContent=code?`ROOM ${code}`:'ROOM';
    header.style.display=code?'inline-flex':'none';
    header.classList.toggle('show',!!code);
  }
  if(mobile){
    mobile.classList.toggle('room-hidden',!code);
    mobile.style.display=code?'flex':'none';
    if(label)label.textContent=(navigator.share&&isMobileViewport())?'Bagi':'Salin';
  }
  if(helpMeta) helpMeta.textContent = G.onlineRanked
    ? `Ranked matchmaking: ${G.matchmakingTier||getCurrentRankTier().name}`
    : (code?`Room aktif: ${code}`:'Belum ada room online aktif.');
}

function updateMobileHelp(){
  const myColor=G.mode==='self'?'w':(G.playerColor||'w');
  const enemyColor=myColor==='w'?'b':'w';
  const myCls=G.state?sideClass(myColor):G.myClass;
  const enemyCls=G.state?sideClass(enemyColor):G.enemyClass;
  const mySkill=SKILLS[myCls]||{};
  const enemySkill=SKILLS[enemyCls]||{};
  const myEl=document.getElementById('helpMySkill');
  const enemyEl=document.getElementById('helpEnemySkill');
  const hapticBtn=document.getElementById('helpHapticBtn');
  const mobileTheme=document.getElementById('mobileThemeLabel');
  if(myEl)myEl.innerHTML=`<b>${mySkill.icon||'⚡'} ${mySkill.name||'Skill kamu'}</b><br/>${mySkill.desc||'Pilih kelas untuk melihat skill.'}`;
  if(enemyEl)enemyEl.innerHTML=`<b>${enemySkill.icon||'⚡'} ${enemySkill.name||'Skill lawan'}</b><br/>${enemySkill.desc||'Skill lawan akan muncul saat match dimulai.'}`;
  if(hapticBtn){
    hapticBtn.textContent=`Getar: ${G.mobilePrefs?.haptics?'ON':'OFF'}`;
    hapticBtn.classList.toggle('btn-gold',!!G.mobilePrefs?.haptics);
    hapticBtn.classList.toggle('btn-outline',!G.mobilePrefs?.haptics);
  }
  if(mobileTheme){
    mobileTheme.textContent=document.documentElement.getAttribute('data-theme')==='light'?'Dark':'Light';
  }
  updateRoomCodeButtons();
}

function toggleMobileHaptics(){
  G.mobilePrefs={...(G.mobilePrefs||{}),haptics:!G.mobilePrefs?.haptics};
  saveMobilePrefs();
  updateMobileHelp();
  showToast(`Getaran ${G.mobilePrefs.haptics?'diaktifkan':'dimatikan'}.`);
  if(G.mobilePrefs.haptics)pulseHaptic('success');
}

function openMobileHelp(){
  updateMobileHelp();
  document.getElementById('mobileHelpModal')?.classList.add('open');
  pulseHaptic('tap');
}

function closeMobileHelp(){
  document.getElementById('mobileHelpModal')?.classList.remove('open');
  if(document.getElementById('gameScreen')?.classList.contains('active')){ refreshDisplayedClassUI(); updatePanels(); updateSkillUI(); }
}

function toggleBoardFlip(silent){
  G.flipped=!G.flipped;
  renderBoard();
  if(!silent){
    showToast('Papan dibalik!');
    pulseHaptic('tap');
  }
}

function scrollMobileTo(id){
  const el=document.getElementById(id);
  if(!el)return;
  el.scrollIntoView({behavior:'smooth',block:'start'});
  pulseHaptic('tap');
}

async function copyTextSmart(text,label='Teks'){
  const value=String(text||'').trim();
  if(!value){showToast(`${label} belum tersedia.`);pulseHaptic('alert');return false;}
  try{
    if(navigator.clipboard?.writeText){
      await navigator.clipboard.writeText(value);
    }else{
      const ta=document.createElement('textarea');
      ta.value=value;
      ta.setAttribute('readonly','');
      ta.style.position='fixed';
      ta.style.opacity='0';
      document.body.appendChild(ta);
      ta.select();
      document.execCommand('copy');
      ta.remove();
    }
    showToast(`${label} disalin.`);
    pulseHaptic('success');
    return true;
  }catch(e){
    showToast(`Gagal menyalin ${label.toLowerCase()}.`);
    pulseHaptic('alert');
    return false;
  }
}

async function copyRoomCode(){
  if(G.onlineRanked){showToast('Ranked matchmaking tidak memakai kode room.');return;}
  const code=String(G.roomCode||document.getElementById('waitCode')?.textContent||'').trim();
  if(!code||code==='----'){showToast('Kode room belum tersedia.');pulseHaptic('alert');return;}
  await copyTextSmart(code,'Kode room');
}

async function shareRoomCode(){
  if(G.onlineRanked){showToast('Ranked matchmaking tidak bisa dibagikan manual.');return;}
  const code=String(G.roomCode||document.getElementById('waitCode')?.textContent||'').trim();
  if(!code||code==='----'){showToast('Kode room belum tersedia.');pulseHaptic('alert');return;}
  const text=`Ayo duel di Chess Fantasy.\nKode room: ${code}`;
  if(navigator.share && isMobileViewport()){
    try{
      await navigator.share({title:'Chess Fantasy Room',text});
      showToast('Kode room dibagikan.');
      pulseHaptic('success');
      return;
    }catch(e){
      if(e?.name==='AbortError')return;
    }
  }
  await copyRoomCode();
}

function setupBoardTouchGestures(){
  const wrap=document.querySelector('.board-wrap');
  if(!wrap || wrap.dataset.touchBound==='1')return;
  wrap.dataset.touchBound='1';
}

function showTurnBanner(title,sub){
  const box=document.getElementById('turnCenterBanner');
  if(!box)return;
  document.getElementById('turnBannerTitle').textContent=title||'GILIRAN KAMU';
  document.getElementById('turnBannerSub').textContent=sub||'Sekarang kamu bisa bergerak.';
  box.classList.add('show');
  clearTimeout(showTurnBanner._timer);
  showTurnBanner._timer=setTimeout(()=>box.classList.remove('show'),850);
}

function refreshJackpotVignette(){
  const el=document.getElementById('jackpotVignette');
  if(!el || !G.state) return;
  let active=false;
  for(let r=0;r<8 && !active;r++) for(let f=0;f<8;f++){
    const p=G.state.board[r][f];
    if(p?.jackpotTurns){ active=true; break; }
  }
  el.classList.toggle('show', active);
}

function maybeAnnounceMyTurn(prevTurn,source){
  if(!G.state || G.gameOver || G.mode==='self')return;
  if(prevTurn===G.playerColor || G.state.turn!==G.playerColor)return;
  const sub=source==='enemy_move'
    ? 'Lawan sudah jalan — sekarang giliranmu.'
    : 'Your turn dimulai. Pilih bidak untuk bergerak.';
  showTurnBanner('GILIRAN KAMU',sub);
  pulseHaptic('alert');
}

function startTutorialMode(){
  G.adminSandbox=false;
  G.tutorialMode=true;
  updateAdminButton();
  G.mode='self';
  G.playerColor='w';
  G.myName=getName();
  G.myClass=document.querySelector('.class-btn.sel')?.dataset.cls||'king';
  G.enemyName='Tutor';
  G.enemyClass='bishop';
  G.rankMode=false;
  G.onlineRanked=false;
  G.selfConfig={w:{name:G.myName,cls:G.myClass},b:{name:'Tutor',cls:G.enemyClass}};
  G.flipped=false;
  initGame();
  showScreen('gameScreen');
  addChatMsg('system','🧭 Tutorial Mode aktif. Baca coach panel di bawah untuk arahan singkat.');
  openTutorialCoach(0);
}
function openTutorialCoach(step=0){
  G.tutorialStep=Math.max(0, Math.min(TUTORIAL_STEPS.length-1, step));
  const cfg=TUTORIAL_STEPS[G.tutorialStep];
  const box=document.getElementById('tutorialCoach');
  if(!cfg||!box) return;
  document.getElementById('tutorialCoachStep').textContent=`Step ${G.tutorialStep+1} / ${TUTORIAL_STEPS.length}`;
  document.getElementById('tutorialCoachTitle').textContent=cfg.title;
  document.getElementById('tutorialCoachHeader').textContent=cfg.header;
  document.getElementById('tutorialCoachText').textContent=cfg.text;
  const list=document.getElementById('tutorialCoachList');
  list.innerHTML=(cfg.bullets||[]).map(x=>`<li>${x}</li>`).join('');
  box.classList.add('show');
}
function closeTutorialCoach(){ document.getElementById('tutorialCoach')?.classList.remove('show'); }
function nextTutorialStep(){
  if(!G.tutorialMode){ startTutorialMode(); return; }
  if(G.tutorialStep>=TUTORIAL_STEPS.length-1){ endTutorialMode(); return; }
  openTutorialCoach(G.tutorialStep+1);
}
function prevTutorialStep(){
  if(!G.tutorialMode) return;
  openTutorialCoach(Math.max(0,G.tutorialStep-1));
}
function endTutorialMode(){
  G.tutorialMode=false;
  closeTutorialCoach();
  showToast('Tutorial mode ditutup.');
}

function openTutorial(){
  document.getElementById('tutorialModal')?.classList.add('open');
  pulseHaptic('tap');
}

function closeTutorial(){
  document.getElementById('tutorialModal')?.classList.remove('open');
  if(document.getElementById('gameScreen')?.classList.contains('active')){ refreshDisplayedClassUI(); updatePanels(); updateSkillUI(); }
}

function setWaitScreen(mode='room', tierName=''){
  const title=document.getElementById('waitTitle');
  const code=document.getElementById('waitCode');
  const sub=document.getElementById('waitSub');
  const actions=document.querySelector('#waitScreen .wait-actions');
  if(mode==='matchmaking'){
    if(title) title.textContent=`Mencari Ranked Match...`;
    if(code) code.textContent=tierName || 'QUEUE';
    if(sub) sub.innerHTML=`Tier kamu: <b>${tierName||'Bronze'}</b><br/>Sistem sedang mencari player yang selevel.`;
    if(actions) actions.style.display='none';
  }else{
    if(title) title.textContent='Waiting Lawan...';
    if(code) code.textContent=G.roomCode||'----';
    if(sub) sub.innerHTML='Bagikan kode ini ke temanmu<br/>Mereka bisa join dari lobby';
    if(actions) actions.style.display='flex';
  }
}

function clearMatchmakingPolling(){
  if(G.matchmakingInterval){ clearInterval(G.matchmakingInterval); G.matchmakingInterval=null; }
}

function beginMatchmakingPolling(){
  clearMatchmakingPolling();
  G.matchmakingInterval=setInterval(async()=>{
    if(!sb || !G.roomId || G.gameOver) return;
    const data=await refreshRoomState();
    if(data?.status==='playing' || data?.status==='finished' || data?.status==='cancelled') clearMatchmakingPolling();
  }, 2500);
}

async function cancelWaiting(){
  clearMatchmakingPolling();
  if(sb && G.roomId && G.roomStatus==='queue'){
    try{ await sb.from('game_rooms').update({status:'cancelled',updated_at:new Date().toISOString()}).eq('id',G.roomId); }catch(e){}
  }
  clearRoomMeta();
  if(G.roomSub) sb?.removeChannel(G.roomSub);
  if(G.chatSub) sb?.removeChannel(G.chatSub);
  G.roomSub=null; G.chatSub=null; G.roomId=null; G.roomCode=null; G.roomStatus='idle';
  showScreen('lobbyScreen');
}

function startPrimaryMode(){
  const mode=getSelectedAiMode();
  if(mode==='ranked_pvp') return startRankedMatchmaking();
  return startVsAI();
}

/* ══════════════════════════════════════════════════════════
   SCREEN MANAGEMENT
══════════════════════════════════════════════════════════ */
function showScreen(id){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  closeMobileHelp();
  closeTutorial();
  updateRoomCodeButtons();
  if(id==='gameScreen'){ refreshDisplayedClassUI(); updatePanels(); updateSkillUI(); }
  if(id==='lobbyScreen'){
    clearInterval(G.timerInterval);
    clearTimeout(G.aiTimer);
    clearMatchmakingPolling();
    if(G.roomSub)sb?.removeChannel(G.roomSub);
    if(G.chatSub)sb?.removeChannel(G.chatSub);
    G.roomSub=null; G.chatSub=null;
  }
}


let skillFxTimer;
function flashSkillBanner(kind, subtitle=''){
  const meta={
    commander:{icon:'✦',title:'ROYAL COMMAND'},
    arcanist:{icon:'❈',title:'ARCANE STORM'},
    guardian:{icon:'⛨',title:'ASTRAL WARD'},
    rider:{icon:'✧',title:'NIGHT LEAP'},
    citadel:{icon:'✠',title:'BASTION SHIFT'},
    vanguard:{icon:'❖',title:'VANGUARD ASCENT'},
    revenant:{icon:'☥',title:'SOUL RECALL'},
    relic:{icon:'⚚',title:'CHAOS RELIC'},
    jackpot:{icon:'🎰',title:'JACKPOT MODE'}
  }[kind] || {icon:'✦',title:'SKILL'};
  const layer=document.getElementById('skillFxLayer');
  if(!layer) return;
  let banner=layer.querySelector('.skill-fx-banner');
  if(!banner){
    banner=document.createElement('div');
    banner.className='skill-fx-banner';
    banner.innerHTML='<div class="skill-fx-icon"></div><div class="skill-fx-title"></div><div class="skill-fx-sub"></div>';
    layer.appendChild(banner);
  }
  banner.className=`skill-fx-banner ${kind}`;
  banner.querySelector('.skill-fx-icon').textContent=meta.icon;
  banner.querySelector('.skill-fx-title').textContent=meta.title;
  banner.querySelector('.skill-fx-sub').textContent=subtitle || 'Skill unleashed';
  banner.classList.add('show');
  clearTimeout(skillFxTimer);
  skillFxTimer=setTimeout(()=>banner.classList.remove('show'),900);
}
function spawnSkillSigil(kind, cell){
  const layer=document.getElementById('skillFxLayer');
  const node=document.querySelector(`.cell[data-r="${cell.r}"][data-f="${cell.f}"]`);
  if(!layer || !node) return;
  const rect=node.getBoundingClientRect();
  const meta={commander:'✦',arcanist:'❈',guardian:'⛨',rider:'✧',citadel:'✠',vanguard:'❖',revenant:'☥',relic:'⚚',jackpot:'🎰'};
  const el=document.createElement('div');
  el.className=`skill-fx-sigil ${kind}`;
  el.dataset.icon=meta[kind] || '✦';
  el.style.left=`${rect.left + rect.width/2}px`;
  el.style.top=`${rect.top + rect.height/2}px`;
  layer.appendChild(el);
  setTimeout(()=>el.remove(),860);
}
function flashSkillCells(kind,cells=[]){
  cells.forEach((cell,idx)=>setTimeout(()=>{
    const node=document.querySelector(`.cell[data-r="${cell.r}"][data-f="${cell.f}"]`);
    if(!node) return;
    node.classList.add('skill-flash',`skill-flash-${kind}`);
    setTimeout(()=>{node.classList.remove('skill-flash',`skill-flash-${kind}`);},820);
  }, idx*50));
}
function triggerSkillFx(kind,{cells=[],subtitle=''}={}){
  flashSkillBanner(kind, subtitle);
  flashSkillCells(kind, cells);
  cells.forEach((cell,idx)=>setTimeout(()=>spawnSkillSigil(kind, cell), idx*70));
}

let jackpotTimer;
function showJackpotCelebration(color,pieceLabel='Bidak spesial'){
  const overlay=document.getElementById('jackpotOverlay');
  const sub=document.getElementById('jackpotSub');
  if(!overlay||!sub)return;
  sub.textContent=`${pieceLabel} milik ${sideName(color)} memasuki mode JACKPOT: bonus langkah sekarang, dan tiap capture memberi bonus langkah lagi.`;
  overlay.classList.add('show');
  document.getElementById('jackpotVignette')?.classList.add('show');
  clearTimeout(jackpotTimer);
  pulseHaptic('jackpot');
  playJackpotSound();
  try{ if(G.mobilePrefs?.haptics && 'vibrate' in navigator) navigator.vibrate([40,60,40,90,60]); }catch(e){}
  jackpotTimer=setTimeout(()=>{
    overlay.classList.remove('show');
    refreshJackpotVignette();
  },1900);
}

