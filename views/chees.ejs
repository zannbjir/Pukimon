   SUPABASE MULTIPLAYER
══════════════════════════════════════════════════════════ */
async function createOnlineRoom(code){
  if(!sb)return;
  const baseState=makeState();
  const payload={
    room_code:code,
    white_player:{id:G.currentUserId,name:G.myName,cls:G.myClass},
    status:'waiting',
    version:0,
    game_state:baseState
  };
  const {data,error}=await sb.from('game_rooms').insert(payload).select().single();
  if(error){showToast('Gagal buat room! Cek tabel Supabase.');return;}
  G.roomId=data.id;
  G.roomVersion=data.version||0;
  G.roomStatus=data.status||'waiting';
  G.state=data.game_state||baseState;
  persistRoomMeta();
  subscribeRoom();
}

async function joinOnlineRoom(code) {
    if (!sb) return;
    
    // 1. Ambil data room untuk melihat siapa lawannya (White Player)
    const { data: room, error: fetchErr } = await sb.from('game_rooms')
        .select('*')
        .eq('room_code', code)
        .eq('status', 'waiting')
        .single();

    if (fetchErr || !room) {
        showToast('Room tidak ditemukan atau sudah penuh!');
        return;
    }

    // 2. Update diri kita sebagai Player Hitam
    const { data: joined, error: updateErr } = await sb.from('game_rooms')
        .update({
            black_player: {
                id: G.currentUserId,
                name: G.myName,
                cls: G.myClass
            },
            status: 'playing',
            updated_at: new Date().toISOString()
        })
        .eq('id', room.id)
        .select()
        .single();

    if (updateErr) {
        showToast('Gagal bergabung: ' + updateErr.message);
        return;
    }

    // 3. SET DATA GLOBAL
    G.roomId = joined.id;
    G.roomVersion = joined.version;
    G.playerColor = 'b'; // Kamu adalah Hitam
    G.flipped = true;    // Putar papan otomatis

    // Identifikasi Lawan (White Player)
    const wp = joined.white_player || {};
    G.enemyName = wp.name || 'Lawan';
    G.enemyClass = wp.cls || 'queen';

    // Sinkronkan konfigurasi sisi
    G.selfConfig = {
        w: { name: G.enemyName, cls: G.enemyClass },
        b: { name: G.myName, cls: G.myClass }
    };

    G.state = joined.game_state || makeState();
    
    // 4. JALANKAN UI
    initGame(); 
    refreshDisplayedClassUI(); // <--- PASTIKAN NAMA & ICON TERUPDATE
    showScreen('gameScreen');
    
    subscribeRoom(); // Mulai dengerin perubahan realtime
    await loadRoomMessages();
}

async function refreshRoomState(){
  if(!sb||!G.roomId)return null;
  const {data}=await sb.from('game_rooms').select('*').eq('id',G.roomId).single();
  if(!data)return null;
  const prevTurn=G.state?.turn;
  G.roomVersion=data.version||0;
  G.roomStatus=data.status||G.roomStatus;
  if(data.game_state){
    G.state=data.game_state;
    G.state.hp={w:100,b:100};
    G.state.debuffs={w:[],b:[]};
    G.lastMove=G.state.moves?.at(-1)?{from:G.state.moves.at(-1).from,to:G.state.moves.at(-1).to}:null;
    renderBoard();updatePanels();updateMoveHistory();maybeAnnounceMyTurn(prevTurn,'remote');checkGameOver();
  }
  return data;
}

function subscribeRoom() {
    if (!sb || !G.roomId) return;
    if (G.roomSub) sb.removeChannel(G.roomSub);
    if (G.chatSub) sb.removeChannel(G.chatSub);

    G.roomSub = sb.channel('room:' + G.roomId)
        .on('postgres_changes', { event: 'UPDATE', schema: 'public', table: 'game_rooms', filter: `id=eq.${G.roomId}` }, async payload => {
            const d = payload.new;
            G.roomVersion = d.version || G.roomVersion;
            G.roomStatus = d.status || G.roomStatus;

            // SINKRONISASI DATA LAWAN (Jika ada perubahan nama/kelas di tengah jalan)
            const wp = d.white_player || {};
            const bp = d.black_player || {};
            
            if (G.playerColor === 'w') {
                G.enemyName = bp.name || 'Menunggu...';
                G.enemyClass = bp.cls || 'queen';
            } else {
                G.enemyName = wp.name || 'Lawan';
                G.enemyClass = wp.cls || 'queen';
            }

            // Update info tampilan (Nama & Kelas di panel samping)
            G.selfConfig = {
                w: { name: wp.name || 'Host', cls: wp.cls || 'king' },
                b: { name: bp.name || 'Guest', cls: bp.cls || 'queen' }
            };

            // Jika status berubah jadi playing saat kita di waitScreen
            if (d.status === 'playing' && document.getElementById('waitScreen')?.classList.contains('active')) {
                clearMatchmakingPolling();
                initGame();
                showScreen('gameScreen');
                await loadRoomMessages();
            }

            // UPDATE STATE CATUR
            if (d.game_state) {
                const prevTurn = G.state?.turn;
                G.state = d.game_state;
                // Reset visual buffer
                G.state.hp = { w: 100, b: 100 };
                G.state.debuffs = { w: [], b: [] };
                
                // Track langkah terakhir untuk highlight kotak
                G.lastMove = G.state.moves?.at(-1) ? { from: G.state.moves.at(-1).from, to: G.state.moves.at(-1).to } : null;

                renderBoard();
                updatePanels(); // <--- Fungsi ini harus mengupdate nama di HTML
                updateMoveHistory();
                maybeAnnounceMyTurn(prevTurn, 'remote');
                checkGameOver();
            }

            if (d.status === 'finished' && !G.gameOver) {
                checkGameOver();
            }
        })
        .subscribe();

    // SUBSCRIBE CHAT (Tetap sama)
    G.chatSub = sb.channel('room_messages:' + G.roomId)
        .on('postgres_changes', { event: 'INSERT', schema: 'public', table: 'room_messages', filter: `room_id=eq.${G.roomId}` }, payload => {
            const m = payload.new;
            addChatMsg('user', m.message, m.username, true);
        })
        .subscribe(async status => {
            if (status === 'SUBSCRIBED' && !G.chatLoaded && G.state) {
                await loadRoomMessages();
            }
        });
}

async function syncOnlineMove(){
  if(!sb||!G.roomId)return;
  const nextVersion=(G.roomVersion||0)+1;
  const updatePayload={game_state:G.state,version:nextVersion,status:G.gameOver?'finished':'playing',updated_at:new Date().toISOString()};
  const {data,error}=await sb.from('game_rooms').update(updatePayload).eq('id',G.roomId).eq('version',G.roomVersion||0).select().single();
  if(error||!data){
    await refreshRoomState();
    showToast('State room diperbarui ulang untuk mencegah tabrakan move.');
    return;
  }
  G.roomVersion=data.version||nextVersion;
  persistRoomMeta();
}

async function restoreRoomFromStorage(){
  try{
    const raw=localStorage.getItem(STORAGE_ROOM_KEY);
    if(!raw||!sb)return;
    const meta=JSON.parse(raw);
    if(!meta?.roomId)return;
    G.roomId=meta.roomId;
    G.roomCode=meta.roomCode;
    G.playerColor=meta.color||'w';
    G.mode='online';
    const data=await refreshRoomState();
    if(!data||data.status==='finished'||data.status==='cancelled')return;
    const wp=data.white_player||{};
    const bp=data.black_player||{};
    if(G.playerColor==='w'){
      G.myName=wp.name||G.myName; G.myClass=wp.cls||G.myClass;
      G.enemyName=bp.name||'Lawan'; G.enemyClass=bp.cls||'queen';
    }else{
      G.myName=bp.name||G.myName; G.myClass=bp.cls||G.myClass;
      G.enemyName=wp.name||'Lawan'; G.enemyClass=wp.cls||'queen';
    }
    G.selfConfig={w:{name:wp.name||'Putih',cls:wp.cls||'king'},b:{name:bp.name||'Hitam',cls:bp.cls||'queen'}};
    G.flipped=G.playerColor==='b';
    G.onlineRanked=String(G.roomCode||'').startsWith('MM');
    if(data.status==='queue'){
      G.roomStatus='queue';
      G.matchmakingTier=(wp.rankTier||wp.rank_tier||bp.rankTier||bp.rank_tier||null);
      setWaitScreen('matchmaking', G.matchmakingTier||getCurrentRankTier().name);
      showScreen('waitScreen');
      subscribeRoom();
      beginMatchmakingPolling();
      showToast('Antrean ranked dipulihkan.');
      return;
    }
    initGame();
    G.state=data.game_state||makeState();
    G.state.hp={w:100,b:100};
    G.state.debuffs={w:[],b:[]};
    G.roomVersion=data.version||0;
    renderBoard();updatePanels();updateMoveHistory();showScreen('gameScreen');subscribeRoom();await loadRoomMessages();
    showToast(`Room ${G.roomCode||''} dipulihkan.`);
  }catch(e){}
}


