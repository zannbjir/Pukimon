  if(!relic)return true;
  if(relic.type==='jackpot' && relic.spawnedBy && relic.spawnedBy!==color)return false;
  return true;
}
function decayBoardStatuses(state,color){
  const board=cloneBoard(state.board);
  for(let r=0;r<8;r++)for(let f=0;f<8;f++){
    const p=board[r][f];
    if(!p||p.c!==color)continue;
    if(p.immortalTurns){
      p.immortalTurns--;
      if(p.immortalTurns<=0) delete p.immortalTurns;
    }
    if(p.jackpotTurns){
      p.jackpotTurns--;
      if(p.jackpotTurns<=0) delete p.jackpotTurns;
    }
  }
  return {...state,board};
}
function addDebuffToState(state){
  return {...state,debuffs:{w:[],b:[]}};
}
function clearOneDebuffFromState(state){
