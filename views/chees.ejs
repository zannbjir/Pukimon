  align-items:center;justify-content:center;gap:4px;box-shadow:0 10px 28px rgba(0,0,0,0.28);
}
.mobile-utility-btn.room-hidden{display:none}
.mu-ico{font-size:16px;line-height:1}
.mu-txt{font-size:9px;letter-spacing:0.08em;color:var(--text2);text-transform:uppercase}
.help-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px}
.help-card{
  background:var(--surface);border:1px solid var(--border);padding:14px;
