/* ══════════ MOBILE PLUS PATCH: CLASSIC MODE + TURN PROMPT ══════════ */
body.no-survival-ui .pc-hp-wrap,
body.no-survival-ui .pc-debuffs,
body.no-survival-ui .mb-hp-line,
body.no-survival-ui .mb-hp-track{display:none!important}
body.no-survival-ui .player-card{padding-bottom:12px}
body.no-survival-ui .mobile-battle-bar{align-items:center}
body.no-survival-ui .mb-state{margin-top:2px}
.turn-center-banner{
  position:fixed;left:50%;top:50%;transform:translate(-50%,-50%) scale(.94);
  z-index:650;min-width:min(86vw,360px);max-width:92vw;
  padding:18px 22px;border-radius:18px;
  border:1px solid rgba(201,169,110,0.34);
  background:rgba(10,10,10,0.94);backdrop-filter:blur(14px);
  box-shadow:0 18px 44px rgba(0,0,0,0.42),0 0 0 1px rgba(201,169,110,0.06) inset;
  text-align:center;pointer-events:none;opacity:0;visibility:hidden;
  transition:opacity .22s ease,transform .22s ease,visibility .22s ease;
}
.turn-center-banner.show{opacity:1;visibility:visible;transform:translate(-50%,-50%) scale(1)}
.tcb-label{font-family:'Cinzel',serif;font-size:22px;font-weight:800;letter-spacing:0.16em;color:var(--gold)}
.tcb-sub{margin-top:6px;font-size:11px;letter-spacing:0.12em;color:var(--text2);line-height:1.7}
.tutorial-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px}
.tutorial-card{background:var(--surface);border:1px solid var(--border);padding:14px;display:flex;flex-direction:column;gap:8px}
.tutorial-card h4{font-family:'Cinzel',serif;font-size:12px;color:var(--gold);letter-spacing:0.12em}
.tutorial-card p,.tutorial-card li{font-size:11px;color:var(--text2);line-height:1.8}
.tutorial-card ul{padding-left:16px}
.tutorial-actions{display:flex;gap:10px;flex-wrap:wrap;margin-top:14px}
.class-focus-modal{width:min(94vw,520px);max-height:min(90vh,860px);overflow:auto;text-align:left}
.class-focus-head{display:flex;align-items:center;gap:14px;margin-bottom:14px}
.class-focus-icon{
  width:72px;height:72px;border-radius:18px;display:flex;align-items:center;justify-content:center;
  background:rgba(201,169,110,0.08);border:1px solid rgba(201,169,110,0.22);
  font-size:34px;flex-shrink:0;box-shadow:0 0 24px rgba(201,169,110,0.08) inset
}
.class-focus-kicker{font-size:9px;letter-spacing:.32em;color:var(--gold);text-transform:uppercase}
.class-focus-name{font-family:'Cinzel',serif;font-size:24px;color:var(--text);margin-top:4px}
.class-focus-lore{margin-top:6px;font-size:12px;line-height:1.8;color:var(--text2)}
.class-focus-skill{
  margin-top:14px;padding:14px;border:1px solid var(--border);background:rgba(255,255,255,0.02);border-radius:12px
}
.class-focus-skill h4,.class-focus-notes h4,.class-focus-plan h4,.guide-plus-card h4,.tutorial-coach-card h4{
  font-family:'Cinzel',serif;font-size:12px;color:var(--gold);letter-spacing:.12em;margin-bottom:8px
}
.class-focus-skill p,.class-focus-plan p,.guide-plus-card p,.guide-plus-card li,.tutorial-coach-card p,.tutorial-coach-card li{
  font-size:11px;line-height:1.85;color:var(--text2)
}
.class-focus-notes{margin-top:12px;display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px}
.class-note{padding:12px;border:1px solid var(--border);background:rgba(255,255,255,0.02);border-radius:12px}
.class-note b{display:block;font-size:10px;letter-spacing:.14em;color:var(--text);margin-bottom:4px}
.class-focus-plan{margin-top:12px;padding:14px;border:1px solid var(--border);background:rgba(201,169,110,0.04);border-radius:12px}
.class-focus-actions{display:flex;gap:10px;justify-content:flex-end;flex-wrap:wrap;margin-top:16px}
.guide-plus-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px;margin-top:14px}
.guide-plus-card{padding:14px;border:1px solid var(--border);background:rgba(255,255,255,.02);border-radius:12px}
.tutorial-coach{
  position:fixed;left:50%;bottom:16px;transform:translateX(-50%) translateY(20px);
  width:min(94vw,520px);z-index:620;opacity:0;pointer-events:none;
  transition:opacity .22s ease, transform .22s ease
}
.tutorial-coach.show{opacity:1;pointer-events:auto;transform:translateX(-50%) translateY(0)}
.tutorial-coach-card{
  padding:16px 16px 14px;border-radius:18px;border:1px solid rgba(201,169,110,.22);
  background:rgba(8,8,8,.92);backdrop-filter:blur(10px);box-shadow:0 18px 48px rgba(0,0,0,.34)
}
.tutorial-coach-top{display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:8px}
.tutorial-coach-step{font-size:9px;letter-spacing:.34em;color:var(--gold);text-transform:uppercase}
.tutorial-coach-title{font-family:'Cinzel',serif;font-size:18px;color:var(--text)}
.tutorial-coach-list{padding-left:18px;margin-top:6px}
.tutorial-coach-actions{display:flex;gap:10px;justify-content:flex-end;flex-wrap:wrap;margin-top:12px}
.tutorial-coach-chip{
  display:inline-flex;align-items:center;gap:6px;padding:6px 10px;border-radius:999px;
  border:1px solid rgba(201,169,110,.22);background:rgba(201,169,110,.08);font-size:10px;color:var(--gold)
}
@media(max-width:640px){
  .class-focus-head{align-items:flex-start}
  .class-focus-notes,.guide-plus-grid{grid-template-columns:1fr}
  .class-focus-name{font-size:22px}
}

@media(max-width:900px){
  .turn-center-banner{top:46%;min-width:min(90vw,340px);padding:16px 18px}
  .tcb-label{font-size:18px}
}
@media(max-width:640px){
  .tutorial-grid{grid-template-columns:1fr}
}


/* ══════════ SIMPLE THEME OVERRIDES ══════════ */
html[data-theme="light"]{
  --bg:#f4f5f7;--surface:#ffffff;--card:#ffffff;--card2:#eef1f4;
  --border:rgba(15,23,42,0.10);--border2:rgba(15,23,42,0.18);
  --gold:#7b5a23;--gold2:#9b7430;--gold-dim:#b48a45;
  --silver:#5c6470;--muted:#6b7280;
  --text:#121417;--text2:rgba(18,20,23,0.68);
  --red:#c2410c;--green:#15803d;--blue:#2563eb;
  --sq-light:#efe5d7;--sq-dark:#cdb79c;
  --sq-sel:rgba(123,90,35,0.26);--sq-move:rgba(123,90,35,0.14);
  --sq-check:rgba(194,65,12,0.24);--sq-last:rgba(123,90,35,0.12);
}
body.no-survival-ui .pc-hp-wrap,
body.no-survival-ui .pc-debuffs,
body.no-survival-ui .mb-hp-line,
body.no-survival-ui .mb-hp-track{display:none!important}
body.simple-theme::before{opacity:.012}
html[data-theme="light"] body::before{opacity:.008}
body.simple-theme .game-header,
body.simple-theme .left-panel,
body.simple-theme .right-panel,
body.simple-theme .lobby-card,
body.simple-theme .player-card,
body.simple-theme .skill-card,
body.simple-theme .chat-window,
body.simple-theme .promo-modal,
body.simple-theme .mobile-battle-bar,
body.simple-theme .mobile-utility-bar{
  backdrop-filter:none;
  box-shadow:none;
}
body.simple-theme .lobby-logo,
body.simple-theme .result-title{
  background:none;
  -webkit-text-fill-color:unset;
  color:var(--text);
}
body.simple-theme .game-header,
body.simple-theme .left-panel,
body.simple-theme .right-panel{background:var(--card)}
body.simple-theme .board-area{background:none}
body.simple-theme .skill-card.activated{animation:none;box-shadow:0 0 0 1px rgba(201,169,110,.28) inset}
body.simple-theme .player-card.active-turn::before{height:3px;background:var(--gold)}
