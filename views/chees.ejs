/* ══════════════════════════════════════════════════════════
   BOARD RENDER
══════════════════════════════════════════════════════════ */
function renderBoard(){
  if (!G.state || !G.state.board) {
        console.log("Menunggu data board...");
        return; 
    }
    const grid = document.getElementById('boardGrid');
  const {board,ep}=G.state;
  const st=G.state;
  const lm=G.legalMovesCache;
  const kInCheck=inCheck(board,G.state.turn);
  const kingPos=kInCheck?findKing(board,st.turn):null;

  let html='';
  for(let dRow=0;dRow<8;dRow++){
    for(let dCol=0;dCol<8;dCol++){
      const rank=G.flipped?dRow:7-dRow;
      const file=G.flipped?7-dCol:dCol;
      const p=board[rank][file];
      const isLight=(rank+file)%2===1;
      const isSel=G.selected&&G.selected[0]===rank&&G.selected[1]===file;
      const isLegal=lm.some(([r,f])=>r===rank&&f===file);
      const isLastFrom=G.lastMove&&G.lastMove.from[0]===rank&&G.lastMove.from[1]===file;
      const isLastTo=G.lastMove&&G.lastMove.to[0]===rank&&G.lastMove.to[1]===file;
      const isCheck=kingPos&&kingPos[0]===rank&&kingPos[1]===file;
      const hasEnemy=p&&p.c!==G.state.turn;
      let cls=`cell ${isLight?'light':'dark'}`;
      if(isSel)cls+=' selected';
      else if(isCheck)cls+=' in-check';
      else if(isLastFrom||isLastTo)cls+=' last-move';
      if(isLegal)cls+=hasEnemy?' legal-capture':' legal-move';
      const shielded=G.shieldedPiece&&G.shieldedPiece.r===rank&&G.shieldedPiece.f===file;
      const locked=p?.locked;
      const powerup=st.powerup&&st.powerup.r===rank&&st.powerup.f===file?st.powerup:null;
      html+=`<div class="${cls}" data-r="${rank}" data-f="${file}" onclick="onCellClick(${rank},${file})">`;
      if(p){
        const sym=SYM[p.c][p.t];
        html+=`<span class="piece ${p.c==='w'?'white-piece':'black-piece'}">${sym}</span>`;
        if(shielded)html+=`<span class="skill-active-badge">🛡</span>`;
        if(locked)html+=`<span class="skill-active-badge">🔒</span>`;
        if(p.immortalTurns)html+=`<span class="skill-active-badge">♾ ${p.immortalTurns}</span>`;
        if(p.jackpotTurns)html+=`<span class="skill-active-badge jackpot-badge">🎰 ${p.jackpotTurns}</span>`;
      }
      if(powerup&&!p)html+=`<span class="board-powerup" title="${POWERUPS[powerup.type].name}">${POWERUPS[powerup.type].icon}</span>`;
      html+='</div>';
    }
  }
  grid.innerHTML=html;
  updateStatus();
  updateSkillDock();
}

function updateStatus(){
  const el=document.getElementById('gameStatus');
  if(!G.state){el.textContent='Belum ada permainan';return;}
  const turn=G.state.turn;
  const isMyTurn=turn===G.playerColor;
  const modeNote=G.adminSandbox
    ? 'ADMIN LAB'
    : (G.mode==='ai'
      ? (G.rankMode ? `RANKED · ${getCurrentRankTier().name}` : `AI · ${(AI_PRESETS[G.aiDifficulty]||AI_PRESETS.beginner).label}`)
      : (G.mode==='online' ? (G.onlineRanked ? `RANKED PVP · ${getCurrentRankTier().name}` : `ROOM ${G.roomCode||'----'}`) : 'CUSTOM'));
  if(G.gameOver){el.innerHTML=`<b>PERTANDINGAN SELESAI</b> · ${modeNote}`;return;}
  if(G.aiThinking){el.innerHTML=`<b>AI sedang berpikir...</b> · ${modeNote}`;return;}
  if(G.skillMode){
    const actor=G.skillOwner||turn;
    const actorLabel=actor==='w'?'WHITE':'BLACK';
    el.innerHTML=`<b>${actorLabel} TARGETING</b> · ${modeNote}`;
    return;
  }
  if(G.mode==='self') el.innerHTML=`<b>${turn==='w'?'WHITE':'BLACK'} TURN</b> · ${modeNote}`;
  else el.innerHTML=`<b>${isMyTurn?'GILIRANMU':'GILIRAN LAWAN'}</b> · ${modeNote}`;
}

/* ══════════════════════════════════════════════════════════
   CELL CLICK
══════════════════════════════════════════════════════════ */

function onCellClick(r,f){
  if(G.gameOver)return;
  if(G.adminPendingAction==='placeRelic'){
    if(G.state.board[r][f]){ showToast('Pilih petak kosong untuk relic.'); return; }
    const owner=(G.adminRelicOwner===undefined)?'w':G.adminRelicOwner;
    G.state={...G.state,powerup:{r,f,type:G.adminRelicType||'jackpot',spawnedBy:owner||null}};
    G.adminPendingAction=null;
    addChatMsg('system',`🧪 Admin Lab menaruh ${POWERUPS[G.state.powerup.type]?.name||G.state.powerup.type} di ${FILES[f]}${r+1}.`);
    renderBoard();
    updatePanels();
    updateAdminLabSummary();
    showToast(`🧪 Relic ${POWERUPS[G.state.powerup.type]?.name||G.state.powerup.type} ditempatkan di ${FILES[f]}${r+1}.`);
    return;
  }
  const activeColor=controlledColor();
  const skillColor=G.skillOwner||activeColor;

  if(G.skillMode==='arcane'){
    const p=G.state.board[r][f];
    if(p&&p.c!==skillColor&&p.t!=='K'&&p.t!=='Q'){
      pushUndoSnapshot('skill_arcane');
      const nb=cloneBoard(G.state.board);
      nb[r][f]=null;
      G.state={...G.state,board:nb,debuffs:{w:[],b:[]}};
      triggerSkillFx('arcanist',{cells:[{r,f}], subtitle:`${SYM[p.c][p.t]} erased by singularity`});
      G.skillMode=null;
      G.skillOwner=null;
      setSkillCooldown(skillColor);
      advanceTurnAfterSkill(skillColor);
      applyTurnStartEffects();
      updateSkillUI();
      renderBoard();
      updatePanels();
      updateMoveHistory();
      if(G.mode==='online')syncOnlineMove();
      addChatMsg('system',`❈ Arcane Storm menghapus ${SYM[p.c][p.t]}! Raja dan Arcanist kebal.`);
      checkGameOver();
      if(!G.gameOver&&G.mode==='ai'&&G.state.turn!==G.playerColor){queueAiMove(140);}
    } else showToast('Pilih bidak musuh non-Raja & non-Arcanist!');
    return;
  }
  if(G.skillMode==='shield'){
    const p=G.state.board[r][f];
    if(p&&p.c===skillColor){
      pushUndoSnapshot('skill_guardian');
      const nb=cloneBoard(G.state.board);
      nb[r][f]={...nb[r][f],immortalTurns:Math.max(nb[r][f].immortalTurns||0,3)};
      delete nb[r][f].locked;
      G.state={...G.state,board:nb};
      triggerSkillFx('guardian',{cells:[{r,f}], subtitle:`Astral Ward on ${SYM[p.c][p.t]}`});
      if(G.shieldedPiece&&G.shieldedPiece.r===r&&G.shieldedPiece.f===f&&G.shieldedPiece.color===skillColor) G.shieldedPiece=null;
      G.skillMode=null;
      G.skillOwner=null;
      setSkillCooldown(skillColor);
      advanceTurnAfterSkill(skillColor);
      applyTurnStartEffects();
      updateSkillUI();
      renderBoard();
      updatePanels();
      updateMoveHistory();
      if(G.mode==='online')syncOnlineMove();
      showToast(`⛨ ${SYM[p.c][p.t]} mendapat Astral Ward selama 3 giliran!`);
      addChatMsg('system',`⛨ ${sideName(skillColor)} memberi Astral Ward pada ${SYM[p.c][p.t]}.`);
      checkGameOver();
      if(!G.gameOver&&G.mode==='ai'&&G.state.turn!==G.playerColor){queueAiMove(140);}
    } else showToast('Pilih bidak milik sisi aktif!');
    return;
  }
  if(G.skillMode==='leap'){
    const p=G.state.board[r][f];
    if(p&&p.c===skillColor&&p.t==='N'){
      G.leapKnight=[r,f];
      G.skillMode='leap2';
      showToast('🌙 Sekarang pilih kotak tujuan!');
      G.selected=[r,f];
      renderBoard();
    } else showToast('Pilih Rider milikmu!');
    return;
  }
  if(G.skillMode==='leap2'){
    const p=G.state.board[r][f];
    if(!p){
      pushUndoSnapshot('skill_rider');
      const [kr,kf]=G.leapKnight;
      const nb=cloneBoard(G.state.board);
      nb[r][f]=nb[kr][kf];
      nb[kr][kf]=null;
      G.state={...G.state,board:nb};
      triggerSkillFx('rider',{cells:[{r:kr,f:kf},{r,f}], subtitle:`Night Leap to ${FILES[f]}${r+1}`});
      G.skillMode=null; G.leapKnight=null; G.selected=null; G.skillOwner=null;
      setSkillCooldown(skillColor);
      advanceTurnAfterSkill(skillColor);
      applyTurnStartEffects();
      updateSkillUI();
      renderBoard();
      updatePanels();
      updateMoveHistory();
      if(G.mode==='online')syncOnlineMove();
      showToast('✧ Rider diteleportasi ke kotak kosong!');
      checkGameOver();
      if(!G.gameOver&&G.mode==='ai'&&G.state.turn!==G.playerColor){queueAiMove(140);}
    } else showToast('Night Leap hanya ke kotak kosong!');
    return;
  }
  if(G.skillMode==='bastion'){
    const p=G.state.board[r][f];
    if(p&&p.c===skillColor){
      const nearRook=(()=>{
        for(let rr=0;rr<8;rr++)for(let ff=0;ff<8;ff++){
          const q=G.state.board[rr][ff];
          if(q&&q.c===skillColor&&q.t==='R'&&Math.abs(rr-r)<=1&&Math.abs(ff-f)<=1) return true;
        }
        return p.t==='R';
      })();
      if(!nearRook){ showToast('Target harus bentengmu atau ally di dekat bentengmu.'); return; }
      pushUndoSnapshot('skill_citadel');
      const nb=cloneBoard(G.state.board);
      nb[r][f]={...nb[r][f],immortalTurns:Math.max(nb[r][f].immortalTurns||0,2)};
      delete nb[r][f].locked;
      G.state={...G.state,board:nb};
      triggerSkillFx('citadel',{cells:[{r,f}], subtitle:`Bastion Pulse on ${SYM[p.c][p.t]}`});
      G.skillMode=null; G.rookShiftFrom=null; G.selected=null; G.skillOwner=null; G.legalMovesCache=[];
      setSkillCooldown(skillColor);
      advanceTurnAfterSkill(skillColor);
      applyTurnStartEffects();
      updatePanels(); updateMoveHistory(); checkGameOver(); renderBoard(); updateSkillUI();
      showToast('✠ Bastion Pulse aktif selama 2 giliran!');
      addChatMsg('system',`✠ ${sideName(skillColor)} memakai Bastion Pulse pada ${SYM[p.c][p.t]}.`);
      if(G.mode==='online')syncOnlineMove();
      if(!G.gameOver&&G.mode==='ai'&&G.state.turn!==G.playerColor){queueAiMove(140);}
    } else showToast('Pilih bentengmu atau ally di dekat bentengmu!');
    return;
  }

  if(G.mode!=='self'&&G.state.turn!==G.playerColor){return;}
  if(G.aiThinking)return;
  const p=G.state.board[r][f];
  if(G.selected){
    const[sr,sf]=G.selected;
    if(G.legalMovesCache.some(([lr,lf])=>lr===r&&lf===f)){
      doMove(sr,sf,r,f);
      return;
    }
  }
  if(p&&p.c===G.state.turn&&p.c===activeColor){
    G.selected=[r,f];
    G.legalMovesCache=legalMoves(G.state.board,r,f,G.state).filter(([tr,tf])=>{
      const tp=G.state.board[tr][tf];
      if(isMoveBlockedByProtection(G.state,r,f,tr,tf)) return false;
      return p?.jackpotTurns ? true : !tp?.locked;
    });
    if(p.locked && !p.jackpotTurns){G.legalMovesCache=[];showToast('🔒 Bidak ini dikunci!');}
    else if(p.locked && p.jackpotTurns){showToast('🎰 Mode JACKPOT menembus efek lock!');}
    renderBoard();
  } else {
    G.selected=null;
    G.legalMovesCache=[];
    renderBoard();
  }
}


function doMove(fromR,fromF,toR,toF,promo){
  const p=G.state.board[fromR][fromF];
  const target=G.state.board[toR][toF];
  const relicAtTarget=G.state?.powerup && G.state.powerup.r===toR && G.state.powerup.f===toF ? G.state.powerup : null;
  if(relicAtTarget && !canTakeRelic(relicAtTarget,p.c)){
    showToast('🎰 Jackpot Relic ini terkunci untuk pemilik relic. Musuh tidak bisa mengambilnya.');
    return;
  }
  if(target?.immortalTurns || target?.jackpotTurns){
    showToast(target?.jackpotTurns ? '🎰 Bidak JACKPOT sedang terlindungi dan tidak bisa ditangkap!' : '♾ Bidak itu sedang terlindungi dan tidak bisa ditangkap!');
    return;
  }
  // Check shield protection
  if(G.shieldedPiece&&target&&G.shieldedPiece.r===toR&&G.shieldedPiece.f===toF&&G.shieldedPiece.color===target.c){
    showToast('🛡 Bidak itu dilindungi!');
    return;
  }
  // Pawn promotion check
  if(p.t==='P'&&(toR===7||toR===0)&&!promo){
    showPromoModal(fromR,fromF,toR,toF,p.c);
    return;
  }
  pushUndoSnapshot('move');
  G.selected=null;
  G.legalMovesCache=[];
  G.lastMove={from:[fromR,fromF],to:[toR,toF]};
  const wasCapture=!!G.state.board[toR][toF];
  G.state=applyMove(G.state,fromR,fromF,toR,toF,promo||'Q');
  if(wasCapture){G.captureCount++;playCapture();}else playMove();
  pulseHaptic(wasCapture?'capture':'move');
  G.moveCount++;
  resolvePowerupLanding(p.c,toR,toF);
  const movedPiece=G.state.board[toR]?.[toF];
  if(wasCapture && movedPiece?.jackpotTurns){
    G.state={...G.state,extraTurn:p.c};
    triggerSkillFx('jackpot',{cells:[{r:toR,f:toF}], subtitle:'JACKPOT CHAIN'});
    showToast('🎰 JACKPOT CHAIN! Capture ini memberimu bonus langkah lagi!');
    addChatMsg('system',`🎰 ${SYM[p.c][movedPiece.t]} melanjutkan JACKPOT chain dan memberi bonus langkah untuk ${sideName(p.c)}.`);
    pulseHaptic('jackpot');
  }
  // Decay shield
  if(G.shieldedPiece){
    G.shieldedPiece.turns--;
    if(G.shieldedPiece.turns<=0)G.shieldedPiece=null;
  }
  // Decay locks
  for(let r=0;r<8;r++)
    for(let f=0;f<8;f++){
      const pc=G.state.board[r][f];
      if(pc?.locked){pc.locked--;if(pc.locked<=0)delete pc.locked;}
    }
  // Extra turn skill
  if(G.state.extraTurn&&G.state.extraTurn===p.c&&G.state.turn!==p.c){
    G.state={...G.state,turn:p.c,extraTurn:null};
    showToast('✦ Royal Command aktif: bonus 1 langkah lagi!');
  }
  applyTurnStartEffects();
  // Check for online sync
  if(G.mode==='online')syncOnlineMove();
  renderBoard();
  updatePanels();
  syncAiSetupUI();
  updateMoveHistory();
  checkGameOver();
  // AI response
  if(!G.gameOver&&G.mode==='ai'&&G.state.turn!==G.playerColor){
    queueAiMove();
  }
}

/* ══════════════════════════════════════════════════════════
   AI MOVE
══════════════════════════════════════════════════════════ */
function aiPickBestOwnPiece(state,color,{allowQueen=true,excludeKing=true}={}){
  let best=null;
  for(let r=0;r<8;r++){
    for(let f=0;f<8;f++){
      const p=state.board[r][f];
      if(!p || p.c!==color)continue;
      if(excludeKing && p.t==='K')continue;
      if(!allowQueen && p.t==='Q')continue;
      let score=PVAL[p.t]||0;
      if(isAttacked(state.board,r,f,opp(color))) score+=90;
      if(p.t==='Q') score+=40;
      if(!best || score>best.score) best={r,f,p,score};
    }
  }
  return best;
}

function aiPickBestEnemyPiece(state,color,{allowQueen=true,excludeKing=true}={}){
  const enemy=opp(color);
  let best=null;
  for(let r=0;r<8;r++){
    for(let f=0;f<8;f++){
      const p=state.board[r][f];
      if(!p || p.c!==enemy)continue;
      if(excludeKing && p.t==='K')continue;
      if(!allowQueen && p.t==='Q')continue;
      let score=PVAL[p.t]||0;
      const legal=legalMoves(state.board,r,f,state).length;
      score += legal*6;
      if(isAttacked(state.board,r,f,color)) score+=24;
      if(!best || score>best.score) best={r,f,p,score};
    }
  }
  return best;
}

function aiKnightTeleportTarget(state,color,fromR,fromF){
  let best=null;
  for(let r=0;r<8;r++){
    for(let f=0;f<8;f++){
      if(state.board[r][f]) continue;
      const dr=Math.abs(r-fromR), df=Math.abs(f-fromF);
      const centerBonus=([2,3,4,5].includes(r)&&[2,3,4,5].includes(f))?25:0;
      let attackBonus=0;
      const temp=cloneBoard(state.board);
      temp[r][f]={...temp[fromR][fromF],m:true};
      temp[fromR][fromF]=null;
      for(const [tr,tf] of rawMoves(temp,r,f,null)){
        const target=temp[tr][tf];
        if(target && target.c!==color) attackBonus=Math.max(attackBonus,(PVAL[target.t]||0)*0.4);
      }
      const safePenalty=isAttacked(temp,r,f,opp(color))?80:0;
      const score=centerBonus+attackBonus-safePenalty-(dr+df)*0.5;
      if(!best || score>best.score) best={r,f,score};
    }
  }
  return best && best.score>0 ? best : null;
}

function aiCitadelShiftTarget(state,color,fromR,fromF){
  let best=null;
  for(let r=0;r<8;r++){
    for(let f=0;f<8;f++){
      if(state.board[r][f]) continue;
      if(r!==fromR && f!==fromF) continue;
      const temp=cloneBoard(state.board);
      temp[r][f]={...temp[fromR][fromF],m:true};
      temp[fromR][fromF]=null;
      let pressure=0;
      for(const [tr,tf] of rawMoves(temp,r,f,null)){
        const target=temp[tr][tf];
        if(target && target.c!==color) pressure=Math.max(pressure,(PVAL[target.t]||0)*0.42);
      }
      const centerBonus=([2,3,4,5].includes(r)&&[2,3,4,5].includes(f))?18:0;
      const safePenalty=isAttacked(temp,r,f,opp(color))?72:0;
      const score=pressure+centerBonus-safePenalty;
      if(!best || score>best.score) best={r,f,score};
    }
  }
  return best && best.score>4 ? best : null;
}


function aiTryUseSkillTurn(){
  if(G.gameOver || G.state.turn!=='b' || skillRemaining('b')>0 || skillUsesLeft('b')<=0 || inCheck(G.state.board,'b')) return false;
  const preset=currentAiPreset();
  if(Math.random()>(preset.skillChance||0.4)) return false;
  const cls=sideClass('b');
  const skill=SKILLS[cls];
  if(!skill) return false;

  if(cls==='king'){
    const mv=getBestMove(G.state,'b');
    const target=mv ? G.state.board[mv.to[0]][mv.to[1]] : null;
    if((target && (PVAL[target.t]||0)>=500) || G.moveCount>=16){
      G.state=skill.apply(G.state,'b');
      setSkillCooldown('b');
      addChatMsg('system',`⚡ AI menggunakan ${skill.name}!`);
      return false;
    }
    return false;
  }

  if(cls==='queen'){
    const target=aiPickBestEnemyPiece(G.state,'b',{allowQueen:false,excludeKing:true});
    if(target && target.score>=(preset.minSkillScore||420)){
      triggerSkillFx('arcanist',{cells:[{r:target.r,f:target.f}], subtitle:`${SYM[target.p.c][target.p.t]} erased by singularity`});
      const nb=cloneBoard(G.state.board);
      const removed=nb[target.r][target.f];
      nb[target.r][target.f]=null;
      G.state={...G.state,board:nb,debuffs:{w:[],b:[]}};
      setSkillCooldown('b');
      advanceTurnAfterSkill('b');
      applyTurnStartEffects();
      showToast(`❈ AI menghapus ${SYM[removed.c][removed.t]} dengan Arcane Storm!`);
      addChatMsg('system',`⚡ AI menggunakan ${skill.name} dan menghapus ${SYM[removed.c][removed.t]}.`);
      renderBoard(); updatePanels(); updateMoveHistory(); checkGameOver();
      return true;
    }
    return false;
  }

  if(cls==='bishop'){
    const own=aiPickBestOwnPiece(G.state,'b',{allowQueen:true,excludeKing:false});
    if(own && own.score>=520){
      const nb=cloneBoard(G.state.board);
      nb[own.r][own.f]={...nb[own.r][own.f],immortalTurns:Math.max(nb[own.r][own.f].immortalTurns||0,3)};
      delete nb[own.r][own.f].locked;
      G.state={...G.state,board:nb};
      setSkillCooldown('b');
      advanceTurnAfterSkill('b');
      applyTurnStartEffects();
      triggerSkillFx('guardian',{cells:[{r:own.r,f:own.f}], subtitle:`Astral Ward on ${SYM['b'][own.p.t]}`});
      showToast(`⛨ AI memberi Astral Ward pada ${SYM['b'][own.p.t]} selama 3 giliran.`);
      addChatMsg('system',`⚡ AI menggunakan ${skill.name}.`);
      renderBoard(); updatePanels(); updateMoveHistory(); checkGameOver();
      return true;
    }
    return false;
  }

  if(cls==='knight'){
    let pick=null;
    for(let r=0;r<8;r++) for(let f=0;f<8;f++){
      const p=G.state.board[r][f];
      if(p && p.c==='b' && p.t==='N'){
        const target=aiKnightTeleportTarget(G.state,'b',r,f);
        if(target && (!pick || target.score>pick.score)) pick={from:[r,f],to:[target.r,target.f],score:target.score};
      }
    }
    if(pick && pick.score>=28){
      const nb=cloneBoard(G.state.board);
      nb[pick.to[0]][pick.to[1]]={...nb[pick.from[0]][pick.from[1]],m:true};
      nb[pick.from[0]][pick.from[1]]=null;
      G.state={...G.state,board:nb};
      setSkillCooldown('b');
      advanceTurnAfterSkill('b');
      applyTurnStartEffects();
      triggerSkillFx('rider',{cells:[{r:pick.from[0],f:pick.from[1]},{r:pick.to[0],f:pick.to[1]}], subtitle:'Night Leap executed'});
      showToast(`✧ AI memindahkan Rider dengan Night Leap.`);
      addChatMsg('system',`⚡ AI menggunakan ${skill.name}.`);
      renderBoard(); updatePanels(); updateMoveHistory(); checkGameOver();
      return true;
    }
    return false;
  }

  if(cls==='rook'){
    let pick=null;
    for(let r=0;r<8;r++) for(let f=0;f<8;f++){
      const p=G.state.board[r][f];
      if(p && p.c==='b'){
        const nearRook=(()=>{
          for(let rr=0;rr<8;rr++) for(let ff=0;ff<8;ff++){
            const q=G.state.board[rr][ff];
            if(q&&q.c==='b'&&q.t==='R'&&Math.abs(rr-r)<=1&&Math.abs(ff-f)<=1) return true;
          }
          return p.t==='R';
        })();
        if(!nearRook) continue;
        const score=(p.t==='R'?34:18)+(p.locked?16:0)+((p.immortalTurns||0)?-18:0);
        if(!pick || score>pick.score) pick={r,f,p,score};
      }
    }
    if(pick && pick.score>=24){
      const nb=cloneBoard(G.state.board);
      nb[pick.r][pick.f]={...nb[pick.r][pick.f],immortalTurns:Math.max(nb[pick.r][pick.f].immortalTurns||0,2)};
      delete nb[pick.r][pick.f].locked;
      G.state={...G.state,board:nb};
      setSkillCooldown('b');
      advanceTurnAfterSkill('b');
      applyTurnStartEffects();
      triggerSkillFx('citadel',{cells:[{r:pick.r,f:pick.f}], subtitle:'Bastion Pulse'});
      showToast(`✠ AI mengaktifkan Bastion Pulse.`);
      addChatMsg('system',`⚡ AI menggunakan ${skill.name}.`);
      renderBoard(); updatePanels(); updateMoveHistory(); checkGameOver();
      return true;
    }
    return false;
  }

  if(cls==='pawn'){
    let bestR=-1,bestF=-1,bestScore=-999,queenAlive=false;
    for(let r=0;r<8;r++) for(let f=0;f<8;f++){
      const p=G.state.board[r][f];
      if(p&&p.c==='b'&&p.t==='Q') queenAlive=true;
      if(p&&p.c==='b'&&p.t==='P'){
        const score=7-r;
        if(score>bestScore){bestScore=score;bestR=r;bestF=f;}
      }
    }
    if(bestR>=0 && bestScore>=4){
      const nb=cloneBoard(G.state.board);
      nb[bestR][bestF]={...nb[bestR][bestF],t:queenAlive?'R':'Q',m:true};
      G.state={...G.state,board:nb};
      setSkillCooldown('b');
      advanceTurnAfterSkill('b');
      applyTurnStartEffects();
      showToast(`🌱 AI memperkuat pion terdepan.`);
      addChatMsg('system',`⚡ AI menggunakan ${skill.name}.`);
      renderBoard(); updatePanels(); updateMoveHistory(); checkGameOver();
      return true;
    }
    return false;
  }

  if(cls==='necromancer'){
    const next=skill.apply(G.state,'b');
    if(next!==G.state){
      G.state=next;
      setSkillCooldown('b');
      advanceTurnAfterSkill('b');
      applyTurnStartEffects();
      addChatMsg('system',`⚡ AI menggunakan ${skill.name}.`);
      renderBoard(); updatePanels(); updateMoveHistory(); checkGameOver();
      return true;
    }
    return false;
  }

  if(cls==='warlock'){
    if(G.moveCount<8 || G.state.powerup) return false;
    G.state=skill.apply(G.state,'b');
    setSkillCooldown('b');
    advanceTurnAfterSkill('b');
    applyTurnStartEffects();
    addChatMsg('system',`⚡ AI menggunakan ${skill.name}.`);
    renderBoard(); updatePanels(); updateMoveHistory(); checkGameOver();
    return true;
  }

  return false;
}

function queueAiMove(delay=null){
  clearTimeout(G.aiTimer);
  clearTimeout(G.aiWatchdog);
  if(G.gameOver || G.mode!=='ai' || G.state.turn===G.playerColor)return;
  const preset=currentAiPreset();
  const [dMin,dMax]=preset.delay || [180,320];
  const wait=delay==null ? (dMin + Math.random()*(dMax-dMin)) : delay;
  G.aiThinking=true;
  updateStatus();
  G.aiTimer=setTimeout(()=>aiMove(), wait);
  G.aiWatchdog=setTimeout(()=>{
    if(G.aiThinking && !G.gameOver && G.mode==='ai' && G.state.turn==='b'){
      console.warn('AI watchdog triggered; forcing fallback.');
      aiMove();
    }
  }, 1800);
}

function aiCommitMove(mv){
  G.lastMove={from:mv.from,to:mv.to};
  const wasCapture=!!G.state.board[mv.to[0]][mv.to[1]];
  G.state=applyMove(G.state,...mv.from,...mv.to);
  if(wasCapture){G.captureCount++;playCapture();}else playMove();
  pulseHaptic(wasCapture?'capture':'move');
  G.moveCount++;
  resolvePowerupLanding('b',mv.to[0],mv.to[1]);
  const movedPiece=G.state.board[mv.to[0]]?.[mv.to[1]];
  if(wasCapture && movedPiece?.jackpotTurns){
    G.state={...G.state,extraTurn:'b'};
    triggerSkillFx('jackpot',{cells:[{r:mv.to[0],f:mv.to[1]}], subtitle:'JACKPOT CHAIN'});
    showToast('🎰 AI memicu JACKPOT CHAIN dan mendapat bonus langkah lagi!');
  }
  if(G.state.extraTurn==='b' && G.state.turn!=='b'){
    G.state={...G.state,turn:'b',extraTurn:null};
    showToast('🤖 AI mendapat bonus langkah!');
  }
  applyTurnStartEffects();
  renderBoard();
  updatePanels();
  updateMoveHistory();
  checkGameOver();
}

function aiMove(){
  clearTimeout(G.aiTimer);
  clearTimeout(G.aiWatchdog);
  if(G.gameOver||G.state.turn===G.playerColor){G.aiThinking=false;return;}
  const prevTurn=G.state.turn;
  try{
    if(aiTryUseSkillTurn()){
      G.aiThinking=false;
      maybeAnnounceMyTurn(prevTurn,'enemy_skill');
      return;
    }
    const mv=getBestMove(G.state,'b') || actionableMoves(G.state,'b')[0] || null;
    G.aiThinking=false;
    if(!mv){checkGameOver();return;}
    aiCommitMove(mv);
    if(!G.gameOver && G.mode==='ai' && G.state.turn==='b'){
      queueAiMove(150);
      return;
    }
    maybeAnnounceMyTurn(prevTurn,'enemy_move');
  }catch(err){
    console.error('AI move failed:',err);
    G.aiThinking=false;
    const fallback=actionableMoves(G.state,'b')[0] || null;
    if(fallback){
      aiCommitMove(fallback);
      if(!G.gameOver && G.mode==='ai' && G.state.turn==='b'){
        queueAiMove(150);
        return;
      }
      maybeAnnounceMyTurn(prevTurn,'enemy_move');
    }else{
      checkGameOver();
    }
  }
}


