document.addEventListener('keydown',e=>{
  if(e.key==='Escape'){
    G.selected=null;G.legalMovesCache=[];
    G.skillMode=null;G.leapKnight=null;
    closeMobileHelp();
    closeTutorial();
    closeAdminLab();
      renderBoard();updateStatus();
  }
  if(e.key==='f'||e.key==='F'){
    toggleBoardFlip();
  }
});


