      for(let r=0;r<8;r++)for(let f=0;f<8;f++) if(!state.board[r][f]) empties.push([r,f]);
      if(!empties.length){showToast('Tidak ada kotak kosong untuk spawn relic.');G.skillOwner=null;return state;}
      const [r,f]=empties[Math.floor(Math.random()*empties.length)];
      const type=(Math.random()<0.05)
        ? 'jackpot'
        : ['corrupt','fortify','tempo','crown','purify'][Math.floor(Math.random()*5)];
      const relic={r,f,type,spawnedBy:color};
      showToast(type==='jackpot' ? `🎰 JACKPOT RELIC muncul di ${FILES[f]}${r+1}! Hanya ${sideName(color)} yang bisa mengambilnya.` : `🔮 ${POWERUPS[type].name} muncul di ${FILES[f]}${r+1}!`);
      addChatMsg('system',type==='jackpot' ? `🎰 Jackpot Relic muncul di ${FILES[f]}${r+1} dan terkunci untuk ${sideName(color)}.` : `🔮 Sebuah relic muncul di ${FILES[f]}${r+1}: ${POWERUPS[type].name}.`);
      triggerSkillFx('relic',{cells:[{r,f}], subtitle:`${POWERUPS[type].name} emerges at ${FILES[f]}${r+1}`});
      return {...state,powerup:relic};
    }
  }
};

