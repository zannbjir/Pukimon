function showPromoModal(fromR,fromF,toR,toF,color){
  const modal=document.getElementById('promoModal');
  const choices=document.getElementById('promoChoices');
  const pieces=['Q','R','B','N'];
  choices.innerHTML=pieces.map(t=>`
    <button class="promo-btn" onclick="doPromo(${fromR},${fromF},${toR},${toF},'${t}')">
      ${SYM[color][t]}
    </button>`).join('');
  modal.classList.add('open');
}

function doPromo(fR,fF,tR,tF,piece){
  document.getElementById('promoModal').classList.remove('open');
  doMove(fR,fF,tR,tF,piece);
}

function applyPowerupEffect(state,color,powerup,toR,toF){
  const kind=powerup?.type;
  let ns={...state,powerup:null,hp:{w:100,b:100},debuffs:{w:[],b:[]}};
  const board=cloneBoard(ns.board);
  const piece=board[toR]?.[toF];
  if(kind==='heal' || kind==='fortify'){
    G.shieldedPiece={r:toR,f:toF,turns:2,color};
    showToast(`🛡 ${sideName(color)} mengambil Guardian Sigil. Bidak itu terlindungi 2 giliran!`);
    addChatMsg('system',`🛡 ${sideName(color)} mengambil Guardian Sigil dan melindungi bidaknya.`);
    return {...ns,board};
  }
  if(kind==='tempo' || kind==='hex'){
    ns={...ns,extraTurn:color,board};
    showToast(`⏩ ${sideName(color)} mendapat langkah ekstra!`);
    addChatMsg('system',`⏩ ${sideName(color)} mengambil Tempo Surge dan siap bergerak lagi.`);
    return ns;
  }
  if(kind==='crown'){
    if(piece?.t==='P'){
      piece.t='Q';
      showToast(`👑 Crown Sigil mempromosikan pion ${sideName(color)} menjadi Ratu!`);
      addChatMsg('system',`👑 Crown Sigil aktif: pion ${sideName(color)} langsung promosi menjadi Ratu.`);
      return {...ns,board};
    }
    showToast(`👑 Crown Sigil memberi tempo tambahan untuk ${sideName(color)}!`);
    addChatMsg('system',`👑 Crown Sigil aktif: ${sideName(color)} mendapat satu langkah ekstra.`);
    return {...ns,board,extraTurn:color};
  }
  if(kind==='purify'){
    if(piece?.locked) delete piece.locked;
    G.shieldedPiece={r:toR,f:toF,turns:2,color};
    showToast(`✨ Purity Rune membersihkan efek buruk dan memberi shield singkat.`);
    addChatMsg('system',`✨ Purity Rune aktif: bidak ${sideName(color)} dibersihkan dan dilindungi.`);
    return {...ns,board};
  }
  if(kind==='snare'){
    let lockedCount=0;
    for(let dr=-1;dr<=1;dr++){
      for(let df=-1;df<=1;df++){
        if(!dr && !df)continue;
        const nr=toR+dr,nf=toF+df;
        if(!inBounds(nr,nf))continue;
        const target=board[nr][nf];
        if(target && target.c!==color && target.t!=='K'){
          target.locked=Math.max(target.locked||0,2);
          lockedCount++;
        }
      }
    }
    showToast(lockedCount?`⛓ Snare Trap mengunci ${lockedCount} bidak lawan di sekitarmu!`:'⛓ Snare Trap aktif, tapi tidak ada bidak lawan di sekitar.');
    addChatMsg('system',lockedCount?`⛓ Snare Trap aktif dan mengunci ${lockedCount} bidak lawan.`:`⛓ Snare Trap aktif, tapi tidak mengenai bidak lawan.`);
    return {...ns,board};
  }
  if(kind==='jackpot'){
    if(powerup.spawnedBy && powerup.spawnedBy!==color){
      showToast('🎰 Jackpot Relic menolak disentuh musuh.');
      return state;
    }
    if(piece){
      const originalType=piece.t;
      if(piece.t==='P') piece.t='Q';
      piece.jackpotTurns=4;
      if(piece.locked) delete piece.locked;
      ns={...ns,board,extraTurn:color};
      const pieceLabel=piece.t!==originalType
        ? `${SYM[color][originalType]} ➜ ${SYM[color][piece.t]}`
        : `${SYM[color][piece.t]}`;
      triggerSkillFx('jackpot',{cells:[{r:toR,f:toF}], subtitle:`${pieceLabel} enters JACKPOT mode`});
      showToast(`🎰 JACKPOT! ${pieceLabel} masuk mode JACKPOT dan langsung mendapat bonus langkah!`);
      addChatMsg('system',`🎰 JACKPOT! ${pieceLabel} milik ${sideName(color)} masuk mode JACKPOT selama 3 giliran. Setiap capture oleh bidak itu memberi bonus langkah lagi.`);
      showJackpotCelebration(color,pieceLabel);
      refreshJackpotVignette();
    }
    return ns;
  }
  if(kind==='corrupt'){
    const enemy=opp(color);
    const pawns=[];
    for(let r=0;r<8;r++)for(let f=0;f<8;f++){
      const p=board[r][f];
      if(p&&p.c===enemy&&p.t==='P')pawns.push([r,f]);
    }
    if(pawns.length){
      const [r,f]=pawns[Math.floor(Math.random()*pawns.length)];
      board[r][f]={...board[r][f],c:color};
      ns={...ns,board};
      showToast(`☣ Sebuah pion musuh berkhianat dan berpindah sisi!`);
      addChatMsg('system',`☣ Corrupt Seed aktif: satu pion ${enemy==='w'?'putih':'hitam'} berubah kubu.`);
    }else{
      G.shieldedPiece={r:toR,f:toF,turns:2,color};
      ns={...ns,board};
      showToast('☣ Tidak ada pion musuh — bidak pengambil mendapat perlindungan singkat.');
      addChatMsg('system',`☣ Corrupt Seed tidak menemukan pion lawan dan berubah menjadi perlindungan 1 giliran.`);
    }
    return ns;
  }
  return {...ns,board};
}

function resolvePowerupLanding(color,toR,toF){
  const relic=G.state?.powerup;
  if(relic&&relic.r===toR&&relic.f===toF){
    if(!canTakeRelic(relic,color)) return;
    G.state=applyPowerupEffect(G.state,color,relic,toR,toF);
  }
}

function advanceTurnAfterSkill(color){
  G.state={...G.state,turn:opp(color),ep:null};
  if(G.shieldedPiece){
    G.shieldedPiece.turns--;
    if(G.shieldedPiece.turns<=0)G.shieldedPiece=null;
  }
  for(let r=0;r<8;r++)
    for(let f=0;f<8;f++){
      const pc=G.state.board[r][f];
      if(pc?.locked){pc.locked--;if(pc.locked<=0)delete pc.locked;}
    }
}

function skillConsumesTurn(skillKey){
  return skillKey!=='king';
}

